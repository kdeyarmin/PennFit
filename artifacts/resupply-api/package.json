    "@workspace/resupply-db": "workspace:*",
    "@workspace/resupply-domain": "workspace:*",
    "@workspace/resupply-email": "workspace:*",
    "@workspace/resupply-integrations": "workspace:*",
    "@workspace/resupply-integrations-airview": "workspace:*",
    "@workspace/resupply-integrations-care-orchestrator": "workspace:*",
    "@workspace/resupply-integrations-health-connect": "workspace:*",
    "@workspace/resupply-messaging": "workspace:*",
    "@workspace/resupply-reminders": "workspace:*",
    "@workspace/resupply-secrets": "workspace:*",
    "@workspace/resupply-telecom": "workspace:*",
    "argon2": "^0.43.0",
    "busboy": "^1.6.0",
