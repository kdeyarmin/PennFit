  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.27.3",
