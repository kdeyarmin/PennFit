    "@workspace/resupply-domain": "workspace:*",
    "@workspace/resupply-telecom": "workspace:*",
    "cors": "^2",
    "ws": "^8.18.0",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.4.1",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "zod": "catalog:"
