# Don't reformat what we don't author. .gitignore is honored
# automatically (dist/, node_modules/, coverage/, etc.).

# Generated API clients (regenerated by scripts/codegen — touching
# them creates pointless churn; they're already excluded from
# eslint.config.mjs for the same reason).
lib/api-client-react/src/*/generated/**
artifacts/resupply-api/src/lib/api-zod/generated/**

# Lockfile is owned by pnpm.
pnpm-lock.yaml

# Claude Code tooling config (skills, hooks, settings, vendored plugin
# manifests) — agent/editor configuration, not authored product source.
# Reformatting it is pointless churn and risks breaking JSON/MD that the
# tooling parses, so keep prettier out of it.
.claude/**

# Build output captured for diagnostic, not authored.
**/dist-profile/**

# Vendored third-party WASM glue downloaded by
# scripts/setup-mediapipe.mjs at predev / prebuild time. Not in git
# (.gitignore covers them) but they sit on disk after a build, and
# `prettier --check .` walks the filesystem — without this entry
# format:check fails locally any time the dev/build script has run.
artifacts/cpap-fitter/public/mediapipe/**
