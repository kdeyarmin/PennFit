{
  "env": {
    "npm_config_user_agent": "pnpm/9.0.0 npm/? node/v20.0.0 linux x64"
  },
  "extraKnownMarketplaces": {
    "anthropics-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}/.claude/hooks/session-start.sh\"",
            "timeout": 600,
            "statusMessage": "Installing workspace dependencies..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}\" && pnpm install --frozen-lockfile 2>&1 | tail -3 && pnpm run build 2>&1 | tail -20; exit 0",
            "timeout": 300,
            "statusMessage": "Building project..."
          }
        ]
      }
    ]
  }
}
