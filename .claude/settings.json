{
  "env": {
    "npm_config_engine_strict": "false",
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0"
  },
  "extraKnownMarketplaces": {
    "anthropics-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}/.claude/hooks/session-start.sh\"",
            "timeout": 600,
            "statusMessage": "Installing workspace dependencies..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}\" && PNPM=$(corepack --version >/dev/null 2>&1 && echo 'corepack pnpm' || echo pnpm) && $PNPM install --frozen-lockfile 2>&1 | tail -3 && $PNPM run build 2>&1 | tail -20; exit 0",
            "timeout": 300,
            "statusMessage": "Building project..."
          }
        ]
      }
    ]
  }
}
