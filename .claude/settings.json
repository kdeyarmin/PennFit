{
  "env": {
    "npm_config_user_agent": "pnpm/9.0.0 npm/? node/v20.0.0 linux x64"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /tmp/cc-agent/66286595/project && pnpm run build 2>&1 | tail -20; exit 0",
            "timeout": 120,
            "statusMessage": "Building project..."
          }
        ]
      }
    ]
  }
}
