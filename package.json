{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "lint": "pnpm run lint:resupply",
    "lint:resupply": "eslint --max-warnings 0 \"lib/resupply-*/src/**/*.{ts,tsx}\" \"artifacts/resupply-api/src/**/*.ts\" \"artifacts/cpap-fitter/src/**/*.{ts,tsx}\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r --if-present run test",
    "test:coverage": "pnpm -r --if-present run test:coverage",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --ui --config e2e/playwright.config.ts",
    "audit": "pnpm audit --audit-level=high"
  },
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "ip-address": ">=10.1.1"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.0"
  }
}
