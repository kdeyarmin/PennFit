{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"for(const f of ['package-lock.json','yarn.lock'])if(require('fs').existsSync(f)){process.stderr.write('\\n[preinstall] ERROR: '+f+' is in the repo root.\\nThis is a pnpm workspace; npm and yarn lockfiles are not supported.\\nRun:  rm '+f+' && pnpm install\\n\\n');process.exit(1)}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "lint": "pnpm run lint:resupply",
    "lint:resupply": "eslint --max-warnings 0 \"lib/resupply-*/src/**/*.{ts,tsx}\" \"artifacts/resupply-api/src/**/*.ts\" \"artifacts/cpap-fitter/src/**/*.{ts,tsx}\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r --if-present run test",
    "test:coverage": "pnpm -r --if-present run test:coverage",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --ui --config e2e/playwright.config.ts",
    "audit": "pnpm audit --audit-level=high"
  },
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "pnpm": ">=10.33.0"
  },
  "pnpm": {
    "overrides": {
      "ip-address": ">=10.1.1",
      "esbuild": ">=0.25.0",
      "@tootallnate/once": ">=3.0.1"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.2"
  }
}
