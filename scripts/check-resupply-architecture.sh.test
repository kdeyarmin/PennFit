export { fake };
EOF
assert_pass "test files in worker/jobs may use buildQueueConfig / boss.createQueue"
rm "$WORK"/artifacts/resupply-api/src/worker/jobs/some.test.ts

echo "[self-test] Rule 15: register function using createQueueWithDlq passes"
cat > "$WORK"/artifacts/resupply-api/src/worker/jobs/good-job.ts <<'EOF'
import type PgBoss from "pg-boss";
import { createQueueWithDlq, VENDOR_SEND_QUEUE_OPTS } from "../lib/queue-options";
export async function registerGoodJob(boss: PgBoss) {
  await createQueueWithDlq(boss, "good.job", VENDOR_SEND_QUEUE_OPTS);
}
EOF
assert_pass "worker job using createQueueWithDlq() helper"
rm "$WORK"/artifacts/resupply-api/src/worker/jobs/good-job.ts

