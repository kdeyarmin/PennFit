#!/usr/bin/env bash
# Negative-test harness for scripts/check-resupply-architecture.sh.
#
# Builds a fixture tree under a temp dir that mimics the parts of the
# repo the checker scans, plants known violations, runs the checker
# against the fixture (via RESUPPLY_CHECK_ROOT), and asserts each
# violation is detected. Then removes the violations and asserts the
# checker passes.
#
# This test exists because an earlier version of the checker computed
# offending matches into a `bad=` variable but never evaluated it,
# silently letting violations through. The architect review caught it.
# Adding fixture-driven tests prevents that regression class from
# recurring.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CHECKER="$REPO_ROOT/scripts/check-resupply-architecture.sh"

WORK="$(mktemp -d -t resupply-check-test.XXXXXX)"
trap 'rm -rf "$WORK"' EXIT

mkdir -p "$WORK"/lib/resupply-contracts/src
mkdir -p "$WORK"/lib/resupply-domain/src
mkdir -p "$WORK"/lib/resupply-db/src
mkdir -p "$WORK"/lib/resupply-telecom/src
mkdir -p "$WORK"/lib/resupply-ai/src
mkdir -p "$WORK"/lib/resupply-audit/src
mkdir -p "$WORK"/lib/resupply-testing/src
mkdir -p "$WORK"/artifacts/resupply-api/src
mkdir -p "$WORK"/artifacts/resupply-worker/src
mkdir -p "$WORK"/artifacts/resupply-dashboard/src

# Baseline: every dir has a clean file. The checker should pass.
echo 'export {};' > "$WORK"/lib/resupply-contracts/src/index.ts
echo 'export {};' > "$WORK"/lib/resupply-domain/src/index.ts
echo 'export {};' > "$WORK"/lib/resupply-db/src/index.ts
echo 'export {};' > "$WORK"/lib/resupply-telecom/src/index.ts
echo 'export {};' > "$WORK"/lib/resupply-ai/src/index.ts
echo 'export {};' > "$WORK"/lib/resupply-audit/src/index.ts
echo 'export {};' > "$WORK"/lib/resupply-testing/src/index.ts
echo 'export {};' > "$WORK"/artifacts/resupply-api/src/index.ts
echo 'export {};' > "$WORK"/artifacts/resupply-worker/src/index.ts
echo 'export {};' > "$WORK"/artifacts/resupply-dashboard/src/index.ts

run_checker() {
  RESUPPLY_CHECK_ROOT="$WORK" bash "$CHECKER" 2>&1
}

assert_pass() {
  local label="$1"
  if run_checker >/dev/null; then
    echo "  PASS: clean tree accepted ($label)"
  else
    echo "  FAIL: clean tree rejected ($label)" >&2
    run_checker >&2 || true
    exit 1
  fi
}

assert_fail_with() {
  local label="$1"; shift
  local needle="$1"; shift
  local out
  if out="$(run_checker)"; then
    echo "  FAIL: violation NOT detected: $label" >&2
    echo "    expected output to contain: $needle" >&2
    echo "    actual output:" >&2
    echo "$out" | sed 's/^/      /' >&2
    exit 1
  fi
  if ! echo "$out" | grep -qF "$needle"; then
    echo "  FAIL: violation detected but wrong message: $label" >&2
    echo "    expected to contain: $needle" >&2
    echo "    actual output:" >&2
    echo "$out" | sed 's/^/      /' >&2
    exit 1
  fi
  echo "  PASS: $label"
}

echo "[self-test] baseline empty tree should pass"
assert_pass "baseline"

echo "[self-test] Rule 1: contracts may only import zod"
echo 'import express from "express";' > "$WORK"/lib/resupply-contracts/src/bad.ts
assert_fail_with "contracts importing express (double-quoted)" \
  "lib/resupply-contracts may only import 'zod' or relative paths"
rm "$WORK"/lib/resupply-contracts/src/bad.ts

echo "[self-test] Rule 1: also catches single-quoted imports"
echo "import pg from 'pg';" > "$WORK"/lib/resupply-contracts/src/bad.ts
assert_fail_with "contracts importing pg (single-quoted)" \
  "lib/resupply-contracts may only import 'zod' or relative paths"
rm "$WORK"/lib/resupply-contracts/src/bad.ts

echo "[self-test] Rule 1: zod is allowed"
echo 'import { z } from "zod";' > "$WORK"/lib/resupply-contracts/src/ok.ts
assert_pass "contracts importing zod"
rm "$WORK"/lib/resupply-contracts/src/ok.ts

echo "[self-test] Rule 1: relative imports are allowed"
echo 'import { foo } from "./foo";' > "$WORK"/lib/resupply-contracts/src/ok.ts
echo 'export const foo = 1;' > "$WORK"/lib/resupply-contracts/src/foo.ts
assert_pass "contracts importing relative"
rm "$WORK"/lib/resupply-contracts/src/ok.ts "$WORK"/lib/resupply-contracts/src/foo.ts

echo "[self-test] Rule 2: domain may not import drizzle-orm"
echo 'import { sql } from "drizzle-orm";' > "$WORK"/lib/resupply-domain/src/bad.ts
assert_fail_with "domain importing drizzle-orm" \
  "lib/resupply-domain must not import I/O packages"
rm "$WORK"/lib/resupply-domain/src/bad.ts

echo "[self-test] Rule 2: domain may not import resupply-db"
echo 'import { x } from "@workspace/resupply-db";' > "$WORK"/lib/resupply-domain/src/bad.ts
assert_fail_with "domain importing @workspace/resupply-db" \
  "lib/resupply-domain must not import I/O packages"
rm "$WORK"/lib/resupply-domain/src/bad.ts

echo "[self-test] Rule 3: db may not import telecom"
echo 'import { x } from "@workspace/resupply-telecom";' > "$WORK"/lib/resupply-db/src/bad.ts
assert_fail_with "db importing telecom" \
  "lib/resupply-db must not import vendor adapters"
rm "$WORK"/lib/resupply-db/src/bad.ts

echo "[self-test] Rule 4: telecom may not import ai"
echo 'import { x } from "@workspace/resupply-ai";' > "$WORK"/lib/resupply-telecom/src/bad.ts
assert_fail_with "telecom importing ai" \
  "lib/resupply-telecom must not import lib/resupply-ai"
rm "$WORK"/lib/resupply-telecom/src/bad.ts

# --- Rule 9: lib/resupply-ai must not touch DB or telephony SDKs -----
echo "[self-test] Rule 9: ai may not import @workspace/resupply-db"
echo 'import { x } from "@workspace/resupply-db";' > "$WORK"/lib/resupply-ai/src/bad.ts
assert_fail_with "ai importing @workspace/resupply-db" \
  "lib/resupply-ai must not import the DB layer or telephony SDKs"
rm "$WORK"/lib/resupply-ai/src/bad.ts

echo "[self-test] Rule 9: ai may not import 'pg' (double-quoted)"
echo 'import { Pool } from "pg";' > "$WORK"/lib/resupply-ai/src/bad.ts
assert_fail_with "ai importing pg (double-quoted)" \
  "lib/resupply-ai must not import the DB layer or telephony SDKs"
rm "$WORK"/lib/resupply-ai/src/bad.ts

echo "[self-test] Rule 9: ai may not import 'pg' (single-quoted)"
echo "import { Pool } from 'pg';" > "$WORK"/lib/resupply-ai/src/bad.ts
assert_fail_with "ai importing pg (single-quoted)" \
  "lib/resupply-ai must not import the DB layer or telephony SDKs"
rm "$WORK"/lib/resupply-ai/src/bad.ts

echo "[self-test] Rule 9: ai may not import 'twilio'"
echo 'import twilio from "twilio";' > "$WORK"/lib/resupply-ai/src/bad.ts
assert_fail_with "ai importing twilio" \
  "lib/resupply-ai must not import the DB layer or telephony SDKs"
rm "$WORK"/lib/resupply-ai/src/bad.ts

echo "[self-test] Rule 9: ai importing 'ws' is allowed"
# The Realtime adapter uses the `ws` package directly to talk to
# OpenAI. This is an explicit carve-out — `ws` is a transport, not a
# vendor SDK, and isolating the OpenAI API surface in this lib is
# exactly what the rule is protecting.
echo 'import WebSocket from "ws";' > "$WORK"/lib/resupply-ai/src/ok.ts
assert_pass "ai importing ws (transport, not a vendor SDK)"
rm "$WORK"/lib/resupply-ai/src/ok.ts

# --- Rule 10: lib/resupply-telecom must not touch DB or AI SDKs ------
echo "[self-test] Rule 10: telecom may not import @workspace/resupply-db"
echo 'import { x } from "@workspace/resupply-db";' > "$WORK"/lib/resupply-telecom/src/bad.ts
assert_fail_with "telecom importing @workspace/resupply-db" \
  "lib/resupply-telecom must not import the DB layer or AI SDKs"
rm "$WORK"/lib/resupply-telecom/src/bad.ts

echo "[self-test] Rule 10: telecom may not import 'pg'"
echo 'import { Pool } from "pg";' > "$WORK"/lib/resupply-telecom/src/bad.ts
assert_fail_with "telecom importing pg" \
  "lib/resupply-telecom must not import the DB layer or AI SDKs"
rm "$WORK"/lib/resupply-telecom/src/bad.ts

echo "[self-test] Rule 10: telecom may not import 'openai'"
echo 'import OpenAI from "openai";' > "$WORK"/lib/resupply-telecom/src/bad.ts
assert_fail_with "telecom importing openai" \
  "lib/resupply-telecom must not import the DB layer or AI SDKs"
rm "$WORK"/lib/resupply-telecom/src/bad.ts

echo "[self-test] Rule 10: telecom may not import '@anthropic-ai/sdk'"
echo 'import Anthropic from "@anthropic-ai/sdk";' > "$WORK"/lib/resupply-telecom/src/bad.ts
assert_fail_with "telecom importing @anthropic-ai/sdk" \
  "lib/resupply-telecom must not import the DB layer or AI SDKs"
rm "$WORK"/lib/resupply-telecom/src/bad.ts

echo "[self-test] Rule 10: telecom importing 'twilio' is allowed"
# The whole point of this lib is to be the ONE place that talks to
# Twilio. The rule blocks AI/DB SDKs, not Twilio.
echo 'import twilio from "twilio";' > "$WORK"/lib/resupply-telecom/src/ok.ts
assert_pass "telecom importing twilio (its own vendor)"
rm "$WORK"/lib/resupply-telecom/src/ok.ts

echo "[self-test] Rule 5: api may not import resupply-testing"
echo 'import { x } from "@workspace/resupply-testing";' > "$WORK"/artifacts/resupply-api/src/bad.ts
assert_fail_with "api importing resupply-testing" \
  "must not import @workspace/resupply-testing"
rm "$WORK"/artifacts/resupply-api/src/bad.ts

echo "[self-test] Rule 6: api may not import Penn Fit lib/db"
echo 'import { db } from "@workspace/db";' > "$WORK"/artifacts/resupply-api/src/bad.ts
assert_fail_with "api importing @workspace/db" \
  "must not import Penn Fit packages"
rm "$WORK"/artifacts/resupply-api/src/bad.ts

echo "[self-test] Rule 6: api may not import Penn Fit lib/api-zod"
echo "import { x } from '@workspace/api-zod';" > "$WORK"/artifacts/resupply-api/src/bad.ts
assert_fail_with "api importing @workspace/api-zod (single-quoted)" \
  "must not import Penn Fit packages"
rm "$WORK"/artifacts/resupply-api/src/bad.ts

echo "[self-test] Rule 6: dashboard may not import @workspace/api-client-react"
# Phase 4 retired the dashboard carve-out. The dashboard now ships
# @workspace/resupply-api-client and is swept by Rule 6 like every
# other resupply source dir.
echo 'import { healthCheck } from "@workspace/api-client-react";' \
  > "$WORK"/artifacts/resupply-dashboard/src/bad.ts
assert_fail_with "dashboard importing @workspace/api-client-react" \
  "must not import Penn Fit packages"
rm "$WORK"/artifacts/resupply-dashboard/src/bad.ts

echo "[self-test] Rule 6: dashboard may not import @workspace/db"
echo "import { db } from '@workspace/db';" \
  > "$WORK"/artifacts/resupply-dashboard/src/bad.ts
assert_fail_with "dashboard importing @workspace/db (single-quoted)" \
  "must not import Penn Fit packages"
rm "$WORK"/artifacts/resupply-dashboard/src/bad.ts

echo "[self-test] Rule 6: dashboard may import @workspace/resupply-api-client"
echo 'import { healthCheck } from "@workspace/resupply-api-client";' \
  > "$WORK"/artifacts/resupply-dashboard/src/ok.ts
assert_pass "dashboard importing resupply-api-client"
rm "$WORK"/artifacts/resupply-dashboard/src/ok.ts

echo "[self-test] Rule 7: api may not construct 'new Pool('"
echo "import { Pool } from 'pg';" > "$WORK"/artifacts/resupply-api/src/bad.ts
echo "const p = new Pool({});" >> "$WORK"/artifacts/resupply-api/src/bad.ts
assert_fail_with "api constructing new Pool(" \
  "must not construct its own Postgres pool"
rm "$WORK"/artifacts/resupply-api/src/bad.ts

echo "[self-test] Rule 7: api may not construct 'new pg.Pool(' (namespace form)"
echo "import pg from 'pg';" > "$WORK"/artifacts/resupply-api/src/bad.ts
echo "const p = new pg.Pool({});" >> "$WORK"/artifacts/resupply-api/src/bad.ts
assert_fail_with "api constructing new pg.Pool(" \
  "must not construct its own Postgres pool"
rm "$WORK"/artifacts/resupply-api/src/bad.ts

echo "[self-test] Rule 7: worker may not import from 'pg' (closes alias bypass)"
# Without this guard, a contributor could write
# `import { Pool as Whatever } from "pg"; new Whatever()` and slip past
# the Pool-name check.
echo "import { Pool as PgPoolAlias } from 'pg';" \
  > "$WORK"/artifacts/resupply-worker/src/bad.ts
assert_fail_with "worker importing from pg" \
  "must not construct its own Postgres pool or import 'pg' directly"
rm "$WORK"/artifacts/resupply-worker/src/bad.ts

echo "[self-test] Rule 7: dashboard may not import from 'pg'"
echo 'import { Pool } from "pg";' \
  > "$WORK"/artifacts/resupply-dashboard/src/bad.ts
assert_fail_with "dashboard importing from pg" \
  "must not construct its own Postgres pool or import 'pg' directly"
rm "$WORK"/artifacts/resupply-dashboard/src/bad.ts

echo "[self-test] Rule 7: resupply-api-client may not import from 'pg'"
mkdir -p "$WORK"/lib/resupply-api-client/src
echo 'export {};' > "$WORK"/lib/resupply-api-client/src/index.ts
echo "import { Pool } from 'pg';" \
  > "$WORK"/lib/resupply-api-client/src/bad.ts
assert_fail_with "resupply-api-client importing from pg" \
  "must not construct its own Postgres pool or import 'pg' directly"
rm "$WORK"/lib/resupply-api-client/src/bad.ts

echo "[self-test] Rule 7: test files are exempt"
echo "import { Pool } from 'pg';" \
  > "$WORK"/artifacts/resupply-api/src/foo.test.ts
echo "const p = new Pool({});" \
  >> "$WORK"/artifacts/resupply-api/src/foo.test.ts
assert_pass "api test file may construct Pool"
rm "$WORK"/artifacts/resupply-api/src/foo.test.ts

echo "[self-test] Rule 7: resupply-db may construct its own Pool"
echo "import { Pool } from 'pg';" > "$WORK"/lib/resupply-db/src/pool-ok.ts
echo "export const p = new Pool({});" >> "$WORK"/lib/resupply-db/src/pool-ok.ts
assert_pass "resupply-db constructing Pool"
rm "$WORK"/lib/resupply-db/src/pool-ok.ts

echo "[self-test] Rule 8: api may not call .insert(auditLog ...)"
echo "import { auditLog } from '@workspace/resupply-db';" \
  > "$WORK"/artifacts/resupply-api/src/bad.ts
echo "await db.insert(auditLog).values({});" \
  >> "$WORK"/artifacts/resupply-api/src/bad.ts
assert_fail_with "api calling .insert(auditLog)" \
  "must not write to audit_log directly"
rm "$WORK"/artifacts/resupply-api/src/bad.ts

echo "[self-test] Rule 8: worker may not raw 'INSERT INTO audit_log'"
echo "await pool.query('INSERT INTO audit_log (...) VALUES (...)');" \
  > "$WORK"/artifacts/resupply-worker/src/bad.ts
assert_fail_with "worker raw INSERT INTO audit_log" \
  "must not write to audit_log directly"
rm "$WORK"/artifacts/resupply-worker/src/bad.ts

echo "[self-test] Rule 8: schema-qualified 'INSERT INTO resupply.audit_log' also banned"
echo 'await pool.query("INSERT INTO resupply.audit_log (...) VALUES (...)");' \
  > "$WORK"/artifacts/resupply-api/src/bad.ts
assert_fail_with "api raw INSERT INTO resupply.audit_log" \
  "must not write to audit_log directly"
rm "$WORK"/artifacts/resupply-api/src/bad.ts

echo "[self-test] Rule 8: case-insensitive (lowercase 'insert into ...') still banned"
echo 'await pool.query("insert into audit_log (...) values (...)");' \
  > "$WORK"/artifacts/resupply-worker/src/bad.ts
assert_fail_with "worker lowercase 'insert into audit_log'" \
  "must not write to audit_log directly"
rm "$WORK"/artifacts/resupply-worker/src/bad.ts

echo "[self-test] Rule 8: SELECT from audit_log is allowed"
echo 'await pool.query("SELECT * FROM resupply.audit_log WHERE id = $1");' \
  > "$WORK"/artifacts/resupply-api/src/ok.ts
assert_pass "api SELECT from audit_log"
rm "$WORK"/artifacts/resupply-api/src/ok.ts

echo "[self-test] Rule 8: DELETE from audit_log (test cleanup) is allowed"
echo 'await pool.query("DELETE FROM resupply.audit_log WHERE metadata->>$1 = $2");' \
  > "$WORK"/artifacts/resupply-api/src/ok.ts
assert_pass "api DELETE from audit_log"
rm "$WORK"/artifacts/resupply-api/src/ok.ts

echo "[self-test] Rule 8: bare 'import { auditLog }' is banned outside the helper"
# The two-step alias bypass `import { auditLog }; const al = auditLog;
# db.insert(al)` would slip past every `.insert(...audit...)` regex.
# Banning the IMPORT itself kills the entire bypass family — without
# the import, `auditLog` simply isn't in scope. The legitimate factory
# in lib/resupply-testing imports the public AuditEvent input type
# from @workspace/resupply-audit instead of the schema symbol, so this
# ban has zero false positives in the live tree (verified during the
# 2026-04 hardening pass).
echo "import { auditLog } from '@workspace/resupply-db';" \
  > "$WORK"/lib/resupply-testing/src/bad.ts
echo "type X = typeof auditLog;" \
  >> "$WORK"/lib/resupply-testing/src/bad.ts
assert_fail_with "testing bare import { auditLog }" \
  "must not write to audit_log directly"
rm "$WORK"/lib/resupply-testing/src/bad.ts

echo "[self-test] Rule 8: lib/resupply-audit/src/ IS allowed to write audit_log"
mkdir -p "$WORK"/lib/resupply-audit/src
echo "import { auditLog } from '@workspace/resupply-db';" \
  > "$WORK"/lib/resupply-audit/src/helper.ts
echo "export async function w(db: any) { await db.insert(auditLog).values({}); }" \
  >> "$WORK"/lib/resupply-audit/src/helper.ts
assert_pass "audit helper itself writing audit_log"
rm "$WORK"/lib/resupply-audit/src/helper.ts

echo "[self-test] Rule 8: namespaced .insert(schema.auditLog) bypass is banned"
# Without the namespaced pattern, a contributor could route around
# the bare-symbol check via `db.insert(schema.auditLog).values(...)`
# pulled off a tables namespace import.
echo "import { schema } from '@workspace/resupply-db';" \
  > "$WORK"/artifacts/resupply-api/src/bad.ts
echo "await db.insert(schema.auditLog).values({});" \
  >> "$WORK"/artifacts/resupply-api/src/bad.ts
assert_fail_with "api .insert(schema.auditLog) namespaced bypass" \
  "must not write to audit_log directly"
rm "$WORK"/artifacts/resupply-api/src/bad.ts

echo "[self-test] Rule 8: aliased import bypass (auditLog as al) is banned"
# Without the import-rename ban, `import { auditLog as al }` followed
# by `db.insert(al)` would slip past every `audit`-keyed pattern: the
# insert line wouldn't contain the word `audit` at all.
echo "import { auditLog as al } from '@workspace/resupply-db';" \
  > "$WORK"/artifacts/resupply-worker/src/bad.ts
echo "await db.insert(al).values({});" \
  >> "$WORK"/artifacts/resupply-worker/src/bad.ts
assert_fail_with "worker import { auditLog as al } rename bypass" \
  "must not write to audit_log directly"
rm "$WORK"/artifacts/resupply-worker/src/bad.ts

echo "[self-test] Rule 8: indirect aliasing 'const al = auditLog; .insert(al)' is banned"
# The architect's 2026-04 review flagged this two-step bypass as
# undetected by the symbol-on-the-insert-line pattern alone. The fix
# is the import-side ban: without `import { auditLog }`, the local
# alias has no value to point at. Both the import and the alias-then-
# insert pattern must fail this case for the test to be meaningful.
cat > "$WORK"/artifacts/resupply-api/src/bad.ts <<'EOF'
import { auditLog } from "@workspace/resupply-db";
const al = auditLog;
await db.insert(al).values({});
EOF
assert_fail_with "api indirect aliasing const al = auditLog" \
  "must not write to audit_log directly"
rm "$WORK"/artifacts/resupply-api/src/bad.ts

echo "[self-test] Rule 8: multi-line braced import is banned"
# Without rg's `-U` (multiline) flag, a contributor could split the
# import across lines and slip past every line-oriented regex:
#   import {
#     foo,
#     auditLog as al,
#   } from "@workspace/resupply-db";
# With `-U` enabled and `[^}]*` spanning newlines, the import-side
# pattern catches it.
cat > "$WORK"/artifacts/resupply-worker/src/bad.ts <<'EOF'
import {
  foo,
  auditLog as al,
} from "@workspace/resupply-db";
await db.insert(al).values({});
EOF
assert_fail_with "worker multi-line braced import with auditLog" \
  "must not write to audit_log directly"
rm "$WORK"/artifacts/resupply-worker/src/bad.ts

echo "[self-test] Rule 8: multi-line .insert(\\n  schema.auditLog\\n) is banned"
# `.insert(<ident>?audit*)` must match across newlines under `-U` so
# a pretty-printed call cannot escape the gate. `\s*` in the pattern
# accommodates the embedded newline + indent.
cat > "$WORK"/artifacts/resupply-api/src/bad.ts <<'EOF'
import { schema } from "@workspace/resupply-db";
await db.insert(
  schema.auditLog,
).values({});
EOF
assert_fail_with "api multi-line .insert(schema.auditLog)" \
  "must not write to audit_log directly"
rm "$WORK"/artifacts/resupply-api/src/bad.ts

echo "[self-test] Rule 8: multi-line raw 'INSERT\\n  INTO ... audit_log' is banned"
# A SQL writer that pretty-prints across lines must still hit the
# raw-INSERT pattern. With `-U` and `[^;]*` (which spans newlines),
# the gap matcher reaches the audit_log token without crossing a
# statement terminator.
cat > "$WORK"/artifacts/resupply-worker/src/bad.ts <<'EOF'
await pool.query(`
  INSERT INTO
    resupply.audit_log (action)
  VALUES ($1)
`, ["x"]);
EOF
assert_fail_with "worker multi-line raw INSERT INTO audit_log" \
  "must not write to audit_log directly"
rm "$WORK"/artifacts/resupply-worker/src/bad.ts

echo "[self-test] Rule 8: template-literal interpolated INSERT INTO …audit_log is banned"
# `INSERT INTO \${schema}.audit_log` would slip past a strict
# `INSERT INTO (resupply\.)?audit_log` regex because the schema name
# is dynamic. The broader `INSERT.*audit_log` pattern catches it.
cat > "$WORK"/artifacts/resupply-api/src/bad.ts <<'EOF'
const schema = "resupply";
await pool.query(`INSERT INTO ${schema}.audit_log (action) VALUES ($1)`, ["x"]);
EOF
assert_fail_with "api template-literal INSERT INTO \${schema}.audit_log" \
  "must not write to audit_log directly"
rm "$WORK"/artifacts/resupply-api/src/bad.ts

echo "[self-test] Rule 8: non-audit insert is still allowed (no false positive)"
# Sanity: ensure the broadened patterns don't fire on innocent code.
echo "await db.insert(patients).values({ id: '1' });" \
  > "$WORK"/artifacts/resupply-api/src/ok.ts
assert_pass "api .insert(patients) is fine"
rm "$WORK"/artifacts/resupply-api/src/ok.ts

echo "[self-test] Rule 8: comment mentioning audit_log is NOT a violation"
# A comment describing the helper shouldn't trip the regex (would
# require a separate INSERT keyword on the same line).
echo "// Use logAudit() to write to resupply.audit_log; do not call insert() directly." \
  > "$WORK"/artifacts/resupply-api/src/ok.ts
assert_pass "api comment mentioning audit_log"
rm "$WORK"/artifacts/resupply-api/src/ok.ts

echo "[self-test] Rule 8 KNOWN LIMITATION: SQL split across string-literal boundaries is NOT detected"
# This is INTENTIONALLY a passing case — it documents what the
# regex-only check cannot catch. An attacker who actively wants to
# evade Rule 8 can split the SQL across string concatenation:
#   await pool.query("INSERT INTO " + "resupply.audit_log …")
# The closing `"` of the first literal stops the matcher's gap
# before it reaches `audit_log`. Tightening the gap to allow `"`
# would re-open the comment-INSERT-near-DELETE false positive,
# which is the much more common day-to-day failure mode.
#
# This test pins the gap explicitly so:
#   * a future "tighten the regex" commit that breaks the
#     comment-vs-DELETE no-false-positive test ALSO has to confront
#     this case (it'll start failing because what was a pass becomes
#     a flag);
#   * the gap is visible in the test inventory rather than buried
#     in a comment;
#   * the proper fix (AST-based raw-SQL sink check) has a concrete
#     reproducer to point at when scoping that work.
cat > "$WORK"/artifacts/resupply-api/src/ok.ts <<'EOF'
await pool.query("INSERT INTO " + "resupply.audit_log (action) VALUES ($1)", ["x"]);
EOF
assert_pass "api SQL concatenated across string boundaries (KNOWN GAP — see Rule 8 docs)"
rm "$WORK"/artifacts/resupply-api/src/ok.ts

echo "[self-test] Rule 8: comment with 'INSERT' near a legal DELETE FROM audit_log is NOT a violation"
# Real regression caught during the 2026-04 hardening: when the gap
# matcher used `[^;]*` it spanned across newlines from a comment-
# INSERT to a legitimate DELETE statement's `audit_log` token, since
# there was no `;` between them. The fix excluded string-literal
# boundaries (backtick / `"` / `'`) from the gap so the matcher can't
# bridge from a comment into a string-quoted DELETE. This test pins
# that fix down so the regression cannot return silently.
cat > "$WORK"/lib/resupply-testing/src/ok.ts <<'EOF'
// SELECT/DELETE against audit_log are explicitly allowed under
// architecture-check Rule 8; only INSERT is restricted to the helper.
await pool.query(
  "DELETE FROM resupply.audit_log WHERE metadata->>'_factoriesTag' = $1",
  [tag],
);
EOF
assert_pass "testing comment with INSERT word + legal DELETE FROM audit_log"
rm "$WORK"/lib/resupply-testing/src/ok.ts

echo "[self-test] Final clean-tree check"
assert_pass "post-test cleanup"

echo ""
echo "All resupply-architecture self-tests passed."
