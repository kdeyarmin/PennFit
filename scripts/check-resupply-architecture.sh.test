export async function registerBadJob(boss: PgBoss) {
  await boss.createQueue("bad.job");
}
EOF
assert_fail_with "worker job calling boss.createQueue() directly" \
  "must create queues via createQueueWithDlq"
rm "$WORK"/artifacts/resupply-api/src/worker/jobs/bad-job.ts

echo "[self-test] Rule 15: worker jobs may not call buildQueueConfig() directly"
