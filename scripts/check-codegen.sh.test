#!/usr/bin/env bash
# Self-test for scripts/check-codegen.sh.
#
# Task #37 deleted both spec packages this checker used to drive
# (`@workspace/resupply-api-spec` and `@workspace/api-spec`), so the
# script's SPECS array is empty and it short-circuits on success
# without touching the working tree. The pre-Task-#37 self-test
# corrupted real generated files in `lib/resupply-api-client` and
# `lib/api-zod` to verify the failure path; with the loop disabled
# those scenarios would silently pass (the empty checker never reads
# the generated files at all) and leave the corrupted markers behind
# in a real lib if the test crashed before its restore step.
#
# Until a spec package returns, this self-test only verifies the
# documented no-op contract:
#
#   1. The script exits 0 with no spec packages registered.
#   2. The script prints the "(no spec packages to check …)" line so
#      future contributors know where to look in check-codegen.sh.
#
# When a spec is re-introduced, expand SPECS in check-codegen.sh AND
# restore the per-scenario corruption tests here. Until then, keeping
# an empty self-test active still asserts the script is shell-valid
# (`set -euo pipefail` parses, the empty-array guard works under
# `set -u`) and that the safety message stays in place.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CHECKER="$REPO_ROOT/scripts/check-codegen.sh"
WORK="$(mktemp -d)"
trap 'rm -rf "$WORK"' EXIT

LOG="$WORK/checker.log"

if ! bash "$CHECKER" >"$LOG" 2>&1; then
  echo "[self-test] FAIL: checker exited non-zero on the empty-SPECS no-op path" >&2
  sed 's/^/    /' "$LOG" >&2
  exit 1
fi

if ! grep -qF '(no spec packages to check' "$LOG"; then
  echo "[self-test] FAIL: empty-SPECS guard message missing — did SPECS get repopulated without restoring the per-scenario tests?" >&2
  sed 's/^/    /' "$LOG" >&2
  exit 1
fi

echo "[self-test] PASS (no-op contract: empty SPECS, exit 0, guard message present)"
