#!/usr/bin/env bash
# Self-test for scripts/check-codegen.sh.
#
# We can't easily build a fixture monorepo (orval needs a real spec +
# package layout to do anything useful), so the strategy is to run the
# checker in-place against the actual specs.
#
# Three scenarios cover the contract:
#
#   Scenario A — clean tree:
#     The committed generated files match each spec. The checker
#     must exit 0 and leave EVERY generated dir byte-identical.
#
#   Scenario B — corrupted resupply file:
#     Mutate one file in lib/resupply-api-client/src/generated. The
#     checker must (a) exit non-zero (drift detected) and (b) leave
#     the file with our marker still in place — the checker is
#     supposed to preserve whatever was on disk when it started, NOT
#     silently overwrite the user's edits with regenerated output. If
#     it overwrote the marker, a developer who hand-edited a generated
#     file (even by mistake) would lose their edit on the next
#     validation run with no warning.
#
#   Scenario C — corrupted Penn Fit *zod* file:
#     This specifically guards against a memoization bug. The Penn Fit
#     spec produces TWO output directories from one orval invocation
#     (api-client-react AND api-zod). An earlier version of the
#     checker snapshotted per output dir just-in-time, so when it
#     processed the react dir first orval would mutate the zod dir,
#     and the zod snapshot — taken next — would already contain the
#     regenerated bytes. Result: zod-only drift went undetected and
#     local zod edits were silently overwritten. This scenario fails
#     loudly if that regression ever returns.
#
# These three scenarios together guard:
#   - The checker silently passing when files differ (the same class
#     of bug the architecture-checker self-test was added to catch).
#   - The checker leaving the working tree dirty after a failure,
#     which would make local re-runs surprising and CI hard to reason
#     about.
#   - Penn Fit's dual-output spec being treated as one regeneration
#     unit, not as two independent pipelines.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CHECKER="$REPO_ROOT/scripts/check-codegen.sh"

RESUPPLY_VICTIM="$REPO_ROOT/lib/resupply-api-client/src/generated/api.schemas.ts"
# Pick any committed file under the zod output. Using api.schemas.ts
# would risk it not existing — types/index.ts is reliably present.
ZOD_VICTIM="$REPO_ROOT/lib/api-zod/src/generated/api.ts"

for v in "$RESUPPLY_VICTIM" "$ZOD_VICTIM"; do
  if [[ ! -f "$v" ]]; then
    printf 'self-test setup error: victim file %s missing\n' "$v" >&2
    exit 2
  fi
done

# Snapshot every directory we mutate so we can guarantee restoration
# on any exit path (success, failure, ctrl-c).
SNAPSHOT="$(mktemp -d -t codegen-selftest.XXXXXX)"
mkdir -p "$SNAPSHOT/resupply" "$SNAPSHOT/penn-react" "$SNAPSHOT/penn-zod"
cp -a "$REPO_ROOT/lib/resupply-api-client/src/generated/." "$SNAPSHOT/resupply/"
cp -a "$REPO_ROOT/lib/api-client-react/src/generated/." "$SNAPSHOT/penn-react/"
cp -a "$REPO_ROOT/lib/api-zod/src/generated/." "$SNAPSHOT/penn-zod/"

restore_all() {
  rm -rf \
    "$REPO_ROOT/lib/resupply-api-client/src/generated" \
    "$REPO_ROOT/lib/api-client-react/src/generated" \
    "$REPO_ROOT/lib/api-zod/src/generated"
  mkdir -p \
    "$REPO_ROOT/lib/resupply-api-client/src/generated" \
    "$REPO_ROOT/lib/api-client-react/src/generated" \
    "$REPO_ROOT/lib/api-zod/src/generated"
  cp -a "$SNAPSHOT/resupply/." "$REPO_ROOT/lib/resupply-api-client/src/generated/"
  cp -a "$SNAPSHOT/penn-react/." "$REPO_ROOT/lib/api-client-react/src/generated/"
  cp -a "$SNAPSHOT/penn-zod/." "$REPO_ROOT/lib/api-zod/src/generated/"
  rm -rf "$SNAPSHOT"
}
trap restore_all EXIT

fail() {
  printf 'self-test FAIL: %s\n' "$*" >&2
  exit 1
}

# ---------- Scenario A: clean tree ----------
printf '[self-test] scenario A: clean tree should pass\n'
if ! bash "$CHECKER" >/dev/null 2>&1; then
  fail "checker rejected an in-sync tree (scenario A)"
fi
# Confirm nothing was rewritten in a way that changed bytes — for
# all three output directories, not just resupply. This catches
# clean-run mutations introduced by future refactors.
for pair in \
  "resupply lib/resupply-api-client/src/generated" \
  "penn-react lib/api-client-react/src/generated" \
  "penn-zod lib/api-zod/src/generated"; do
  set -- $pair
  if ! diff -rq "$SNAPSHOT/$1" "$REPO_ROOT/$2" >/dev/null; then
    fail "checker mutated $2 on a clean run"
  fi
done

# ---------- Scenario B: corrupted resupply file ----------
printf '[self-test] scenario B: corrupted resupply file should fail + preserve marker\n'

ORIGINAL_HASH="$(sha256sum "$RESUPPLY_VICTIM" | awk '{print $1}')"
printf '\n// SELF-TEST DRIFT MARKER (resupply) — must be preserved on failure\n' >>"$RESUPPLY_VICTIM"
CORRUPTED_HASH="$(sha256sum "$RESUPPLY_VICTIM" | awk '{print $1}')"
[[ "$CORRUPTED_HASH" == "$ORIGINAL_HASH" ]] && fail "could not corrupt resupply victim"

if bash "$CHECKER" >/dev/null 2>&1; then
  fail "checker accepted a tree with a known-bad resupply file (scenario B)"
fi
RESTORED_HASH="$(sha256sum "$RESUPPLY_VICTIM" | awk '{print $1}')"
if [[ "$RESTORED_HASH" != "$CORRUPTED_HASH" ]]; then
  fail "checker mutated the corrupted resupply file on failure (hash $RESTORED_HASH != $CORRUPTED_HASH)"
fi
if ! grep -q "SELF-TEST DRIFT MARKER (resupply)" "$RESUPPLY_VICTIM"; then
  fail "checker stripped the local resupply edit on failure"
fi

# Reset resupply victim before scenario C so failure modes don't
# leak between scenarios.
cp -f "$SNAPSHOT/resupply/api.schemas.ts" "$RESUPPLY_VICTIM"

# ---------- Scenario C: corrupted Penn Fit zod file ----------
printf '[self-test] scenario C: corrupted Penn Fit zod file should fail + preserve marker\n'

ZOD_ORIGINAL_HASH="$(sha256sum "$ZOD_VICTIM" | awk '{print $1}')"
printf '\n// SELF-TEST DRIFT MARKER (zod) — must be preserved on failure\n' >>"$ZOD_VICTIM"
ZOD_CORRUPTED_HASH="$(sha256sum "$ZOD_VICTIM" | awk '{print $1}')"
[[ "$ZOD_CORRUPTED_HASH" == "$ZOD_ORIGINAL_HASH" ]] && fail "could not corrupt zod victim"

if bash "$CHECKER" >/dev/null 2>&1; then
  fail "checker accepted a tree with a known-bad zod file (scenario C — memoization regression?)"
fi
ZOD_RESTORED_HASH="$(sha256sum "$ZOD_VICTIM" | awk '{print $1}')"
if [[ "$ZOD_RESTORED_HASH" != "$ZOD_CORRUPTED_HASH" ]]; then
  fail "checker silently overwrote the zod edit on failure (hash $ZOD_RESTORED_HASH != $ZOD_CORRUPTED_HASH)"
fi
if ! grep -q "SELF-TEST DRIFT MARKER (zod)" "$ZOD_VICTIM"; then
  fail "checker stripped the local zod edit on failure"
fi

printf '[self-test] PASS\n'
