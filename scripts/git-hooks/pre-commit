#!/usr/bin/env bash
# managed by scripts/install-hooks.sh
#
# Pre-commit hook: catches resupply / PennPaps fitter drift before the commit
# lands, so developers don't find out at validation time minutes later.
#
# Behavior:
#   - Skipped entirely when no staged file touches the relevant trees.
#   - Selectively runs:
#       * scripts/check-resupply-architecture.sh
#           when resupply lib/ or artifact code changes
#       * scripts/check-resupply-migration-prefix.sh
#           when a new SQL file is added under
#           lib/resupply-db/drizzle/. Enforces the moratorium on new
#           migrations with prefix <= 0066 while the journal/files
#           drift is being reconciled (see the README in that
#           directory for the full rationale).
#
# (The previous OpenAPI codegen drift check was retired when Task #37
#  deleted the spec packages; the per-file dispatch below no longer
#  routes to a `need_codegen` branch.)
#
# (The previous schema/migration co-change check was retired when the
#  Drizzle schema directory was deleted — there is no schema TS file
#  to "edit and forget to migrate" anymore. New migrations are
#  hand-written SQL.)
#   - Both checks run against an isolated snapshot of the staged
#     index — unstaged edits and untracked files are stashed for the
#     duration of the hook and restored after, so the checks see
#     exactly what the commit will introduce. See
#     scripts/git-hooks/lib-staged-snapshot.sh for the contract.
#   - Bypass with `git commit --no-verify` or `SKIP_HOOKS=1 git commit ...`
#     for emergencies (e.g. a hotfix while orval itself is broken).
#   - Safe to run on every commit because both checks restore their
#     working tree on failure (see the headers of those scripts).

set -euo pipefail

if [[ "${SKIP_HOOKS:-0}" == "1" ]]; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ----- Source-of-truth drift warning (Task #47) ---------------------------
# The canonical ref is `main` on github.com/kdeyarmin/PennFit
# (Replit remote-tracking name: subrepl-3ppc2e03/main). When local
# `main` falls more than DRIFT_THRESHOLD commits behind that ref,
# print a non-blocking warning so the developer notices BEFORE they
# branch off a stale base. Uses the cached remote-tracking ref only
# (no network), so it's free.
#
# Silently skipped when:
#   - the remote-tracking ref doesn't exist (fresh clone, different
#     remote name, etc.)
#   - the current branch is not `main` (feature-branch commits
#     shouldn't get nagged on every save)
DRIFT_REMOTE="subrepl-3ppc2e03/main"
if git rev-parse --verify --quiet "$DRIFT_REMOTE" >/dev/null; then
  current_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '')"
  if [[ "$current_branch" == "main" ]]; then
    behind="$(git rev-list --count "main..${DRIFT_REMOTE}" 2>/dev/null || echo 0)"
    if [[ "$behind" -gt 0 ]]; then
      cat >&2 <<EOF
[pre-commit] BLOCKED: you are committing to local 'main' while it is
            $behind commits behind ${DRIFT_REMOTE} (the canonical
            source of truth — see replit.md "Git source of truth").
            Committing here creates drift that turns every push into
            a merge-conflict cleanup.

            Do this instead — put the work on a feature branch:

                git stash                     # if you have uncommitted edits
                git fetch subrepl-3ppc2e03
                git checkout -b <branch-name> ${DRIFT_REMOTE}
                git stash pop                 # if you stashed
                # now commit normally; push the branch and open a PR

            If you truly need to commit on local main (emergency
            hotfix only), align first:

                git fetch subrepl-3ppc2e03
                git merge --ff-only ${DRIFT_REMOTE}

            Last resort bypass (do NOT use for normal work):

                SKIP_HOOKS=1 git commit ...
                    (or)
                git commit --no-verify ...
EOF
      exit 1
    fi
  fi
fi
# ----- end drift warning --------------------------------------------------

# Diff against HEAD when present, otherwise against the empty tree
# (initial commit). Newly-added files are picked up either way.
if git rev-parse --verify HEAD >/dev/null 2>&1; then
  staged="$(git diff --cached --name-only --diff-filter=ACMR HEAD)"
else
  staged="$(git diff --cached --name-only --diff-filter=ACMR)"
fi

if [[ -z "$staged" ]]; then
  exit 0
fi

need_arch=0
need_resupply_prefix=0

while IFS= read -r file; do
  [[ -z "$file" ]] && continue
  # Resupply trees: any change to resupply libs or artifacts can violate
  # an architecture rule, so run the check defensively.
  case "$file" in
    lib/resupply-*/*|artifacts/resupply-*/*)
      need_arch=1
      ;;
  esac
  # Resupply DB migration-prefix moratorium: while the journal/files
  # drift is being reconciled (see lib/resupply-db/drizzle/README.md),
  # any newly-added migration SQL is checked to ensure it doesn't
  # land in the duplicate-prefix set or the unjournaled range.
  # Trigger on any change under lib/resupply-db/drizzle/; the script
  # itself filters to ADDED *.sql files with forbidden prefixes.
  case "$file" in
    lib/resupply-db/drizzle/*|lib/resupply-db/drizzle/*/*)
      need_resupply_prefix=1
      ;;
  esac
done <<< "$staged"

if [[ $need_arch -eq 0 && $need_resupply_prefix -eq 0 ]]; then
  exit 0
fi

# shellcheck source=lib-staged-snapshot.sh
source "$REPO_ROOT/scripts/git-hooks/lib-staged-snapshot.sh"

# Wrapped so a single stash/unstash covers BOTH checks. Inside this
# function the working tree mirrors the staged index; checks see
# exactly what's about to land.
run_checks() {
  local f=0
  # Architecture first: it's the cheapest, so on a multi-failure commit
  # the developer sees the easiest signal at the top of the output.
  if [[ $need_arch -eq 1 ]]; then
    printf '[pre-commit] Running resupply architecture check…\n' >&2
    if ! bash "$REPO_ROOT/scripts/check-resupply-architecture.sh"; then
      f=1
    fi
  fi
  if [[ $need_resupply_prefix -eq 1 ]]; then
    printf '[pre-commit] Running resupply migration-prefix moratorium check…\n' >&2
    if ! bash "$REPO_ROOT/scripts/check-resupply-migration-prefix.sh"; then
      f=1
    fi
  fi
  return $f
}

if ! with_staged_snapshot run_checks; then
  cat >&2 <<'EOF'

[pre-commit] One or more checks failed. Fix the issues above and
re-stage, or skip the hook for this commit with:

    SKIP_HOOKS=1 git commit ...
        (or)
    git commit --no-verify ...

EOF
  exit 1
fi

exit 0
