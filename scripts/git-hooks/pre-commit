#!/usr/bin/env bash
# managed by scripts/install-hooks.sh
#
# Pre-commit hook: catches resupply / PennPaps fitter drift before the commit
# lands, so developers don't find out at validation time minutes later.
#
# Behavior:
#   - Skipped entirely when no staged file touches the relevant trees.
#   - Selectively runs:
#       * scripts/check-codegen.sh
#           when an OpenAPI spec or its generated client tree changes
#       * scripts/check-resupply-architecture.sh
#           when resupply lib/ or artifact code changes
#       * scripts/check-drizzle-drift.sh
#           when a Drizzle schema or migration file changes (catches
#           schema TS edits that were never followed by `generate`)
#   - Both checks run against an isolated snapshot of the staged
#     index — unstaged edits and untracked files are stashed for the
#     duration of the hook and restored after, so the checks see
#     exactly what the commit will introduce. See
#     scripts/git-hooks/lib-staged-snapshot.sh for the contract.
#   - Bypass with `git commit --no-verify` or `SKIP_HOOKS=1 git commit ...`
#     for emergencies (e.g. a hotfix while orval itself is broken).
#   - Safe to run on every commit because both checks restore their
#     working tree on failure (see the headers of those scripts).

set -euo pipefail

if [[ "${SKIP_HOOKS:-0}" == "1" ]]; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Diff against HEAD when present, otherwise against the empty tree
# (initial commit). Newly-added files are picked up either way.
if git rev-parse --verify HEAD >/dev/null 2>&1; then
  staged="$(git diff --cached --name-only --diff-filter=ACMR HEAD)"
else
  staged="$(git diff --cached --name-only --diff-filter=ACMR)"
fi

if [[ -z "$staged" ]]; then
  exit 0
fi

need_codegen=0
need_arch=0
need_drizzle=0

while IFS= read -r file; do
  [[ -z "$file" ]] && continue
  # Spec/client trees: drift only matters when the spec or its generated
  # client changes. Touching unrelated files in those packages (e.g.
  # README) still triggers the check, which is fine — it's cheap when
  # nothing actually drifted.
  case "$file" in
    lib/resupply-api-spec/*|lib/api-spec/*|lib/resupply-api-client/*|lib/api-client-react/*|lib/api-zod/*)
      need_codegen=1
      ;;
  esac
  # Resupply trees: any change to resupply libs or artifacts can violate
  # an architecture rule, so run the check defensively.
  case "$file" in
    lib/resupply-*/*|artifacts/resupply-*/*)
      need_arch=1
      ;;
  esac
  # Drizzle drift: trigger when either the TypeScript schema or the
  # committed migration tree of a covered DB lib changes. Today only
  # lib/db is covered (lib/resupply-db's snapshot meta chain is broken
  # — see scripts/check-drizzle-drift.sh header). Once the resupply
  # snapshot chain is repaired, add the matching patterns for
  # lib/resupply-db here.
  #
  # Bash `case` globs don't cross `/`, so we list each depth
  # explicitly. drizzle/ has top-level migration .sql files AND a
  # drizzle/meta/ subdir of snapshot .json files, both of which can
  # legitimately drift if hand-edited. src/schema/ is currently flat
  # but we cover one level of subdirs defensively.
  case "$file" in
    lib/db/src/schema/*|lib/db/src/schema/*/*|\
    lib/db/drizzle/*|lib/db/drizzle/*/*|\
    lib/db/drizzle.config.ts)
      need_drizzle=1
      ;;
  esac
done <<< "$staged"

if [[ $need_codegen -eq 0 && $need_arch -eq 0 && $need_drizzle -eq 0 ]]; then
  exit 0
fi

# shellcheck source=lib-staged-snapshot.sh
source "$REPO_ROOT/scripts/git-hooks/lib-staged-snapshot.sh"

# Wrapped so a single stash/unstash covers BOTH checks. Inside this
# function the working tree mirrors the staged index; checks see
# exactly what's about to land.
run_checks() {
  local f=0
  # Architecture first: it's the cheapest, so on a multi-failure commit
  # the developer sees the easiest signal at the top of the output.
  if [[ $need_arch -eq 1 ]]; then
    printf '[pre-commit] Running resupply architecture check…\n' >&2
    if ! bash "$REPO_ROOT/scripts/check-resupply-architecture.sh"; then
      f=1
    fi
  fi
  if [[ $need_codegen -eq 1 ]]; then
    printf '[pre-commit] Running OpenAPI codegen drift check…\n' >&2
    if ! bash "$REPO_ROOT/scripts/check-codegen.sh"; then
      f=1
    fi
  fi
  if [[ $need_drizzle -eq 1 ]]; then
    printf '[pre-commit] Running Drizzle migration drift check…\n' >&2
    if ! bash "$REPO_ROOT/scripts/check-drizzle-drift.sh"; then
      f=1
    fi
  fi
  return $f
}

if ! with_staged_snapshot run_checks; then
  cat >&2 <<'EOF'

[pre-commit] One or more checks failed. Fix the issues above and
re-stage, or skip the hook for this commit with:

    SKIP_HOOKS=1 git commit ...
        (or)
    git commit --no-verify ...

EOF
  exit 1
fi

exit 0
