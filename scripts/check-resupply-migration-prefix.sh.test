#!/usr/bin/env bash
#
# Self-test for scripts/check-resupply-migration-prefix.sh.
#
# Builds a throwaway git repo in a tempdir, runs the checker against
# synthetic diffs, asserts pass/fail. Never touches the real working
# tree.
#
# Scenarios:
#   A. clean tree (no migration changes)                            — pass
#   B. add a migration with forbidden prefix (0050)                 — fail
#   C. add a migration at the threshold boundary (0066)             — fail
#   D. add a migration just above the threshold (0067)              — pass
#   E. modify (not add) an existing low-prefix migration            — pass
#   F. add an unrelated file                                        — pass
#   G. duplicate-prefix add (0049 again)                            — fail
#   H. working-tree mode (DIFF_TARGET="") still detects forbidden   — fail
#   I. high-prefix add far above threshold (0099)                   — pass

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT="$REPO_ROOT/scripts/check-resupply-migration-prefix.sh"

if [[ ! -x "$SCRIPT" ]]; then
  printf '[self-test] %s is not executable; chmod +x it first\n' "$SCRIPT" >&2
  exit 1
fi

WORK="$(mktemp -d -t resupply-prefix-test.XXXXXX)"
trap 'rm -rf "$WORK"' EXIT INT TERM

cd "$WORK"
git init -q
git config user.email "test@example.com"
git config user.name "Test"
git commit -q --allow-empty -m "init"

mkdir -p lib/resupply-db/drizzle/meta
echo "-- baseline" > lib/resupply-db/drizzle/0000_init.sql
echo "-- existing low-prefix migration" > lib/resupply-db/drizzle/0049_existing.sql
git add .
git commit -q -m "baseline"

mkdir -p scripts
cp "$SCRIPT" scripts/check-resupply-migration-prefix.sh
chmod +x scripts/check-resupply-migration-prefix.sh

run_check() {
  BASE_REF=HEAD DIFF_TARGET=--cached \
    bash scripts/check-resupply-migration-prefix.sh
}

# --- A: clean staged index --------------------------------------------------
echo "[self-test] scenario A: clean staged index should pass"
if ! run_check >/dev/null 2>&1; then
  echo "[self-test] FAIL: A (clean tree should have passed)" >&2
  exit 1
fi

# --- B: forbidden prefix 0050 -----------------------------------------------
echo "[self-test] scenario B: adding 0050_*.sql should fail"
echo "-- new" > lib/resupply-db/drizzle/0050_forbidden.sql
git add lib/resupply-db/drizzle/0050_forbidden.sql
if run_check >/dev/null 2>&1; then
  echo "[self-test] FAIL: B (0050 add should have failed)" >&2
  exit 1
fi
git restore --staged lib/resupply-db/drizzle/0050_forbidden.sql >/dev/null 2>&1 || true
rm -f lib/resupply-db/drizzle/0050_forbidden.sql

# --- C: threshold boundary 0066 ---------------------------------------------
echo "[self-test] scenario C: adding 0066_*.sql should fail (boundary)"
echo "-- new" > lib/resupply-db/drizzle/0066_boundary.sql
git add lib/resupply-db/drizzle/0066_boundary.sql
if run_check >/dev/null 2>&1; then
  echo "[self-test] FAIL: C (0066 add should have failed)" >&2
  exit 1
fi
git restore --staged lib/resupply-db/drizzle/0066_boundary.sql >/dev/null 2>&1 || true
rm -f lib/resupply-db/drizzle/0066_boundary.sql

# --- D: just above threshold 0067 -------------------------------------------
echo "[self-test] scenario D: adding 0067_*.sql should pass"
echo "-- new" > lib/resupply-db/drizzle/0067_ok.sql
git add lib/resupply-db/drizzle/0067_ok.sql
if ! run_check >/dev/null 2>&1; then
  echo "[self-test] FAIL: D (0067 add should have passed)" >&2
  exit 1
fi
git restore --staged lib/resupply-db/drizzle/0067_ok.sql >/dev/null 2>&1 || true
rm -f lib/resupply-db/drizzle/0067_ok.sql

# --- E: modify existing low-prefix migration --------------------------------
echo "[self-test] scenario E: modifying existing low-prefix migration should pass"
echo "-- edited" >> lib/resupply-db/drizzle/0049_existing.sql
git add lib/resupply-db/drizzle/0049_existing.sql
if ! run_check >/dev/null 2>&1; then
  echo "[self-test] FAIL: E (modify-only should have passed)" >&2
  exit 1
fi
git restore --staged lib/resupply-db/drizzle/0049_existing.sql >/dev/null 2>&1 || true
git checkout -- lib/resupply-db/drizzle/0049_existing.sql

# --- F: unrelated file ------------------------------------------------------
echo "[self-test] scenario F: unrelated edit should pass"
mkdir -p artifacts/cpap-fitter/src
echo "// no migration involvement" > artifacts/cpap-fitter/src/index.ts
git add artifacts/cpap-fitter/src/index.ts
if ! run_check >/dev/null 2>&1; then
  echo "[self-test] FAIL: F (unrelated edit should have passed)" >&2
  exit 1
fi
git restore --staged artifacts/cpap-fitter/src/index.ts >/dev/null 2>&1 || true
rm -rf artifacts

# --- G: duplicate-prefix add (0049 reused) ----------------------------------
echo "[self-test] scenario G: adding another 0049_*.sql should fail"
echo "-- duplicate prefix" > lib/resupply-db/drizzle/0049_duplicate.sql
git add lib/resupply-db/drizzle/0049_duplicate.sql
if run_check >/dev/null 2>&1; then
  echo "[self-test] FAIL: G (duplicate 0049 add should have failed)" >&2
  exit 1
fi
git restore --staged lib/resupply-db/drizzle/0049_duplicate.sql >/dev/null 2>&1 || true
rm -f lib/resupply-db/drizzle/0049_duplicate.sql

# --- H: working-tree mode (DIFF_TARGET="") detects unstaged forbidden add ---
echo "[self-test] scenario H: DIFF_TARGET= mode should fail on unstaged forbidden add"
echo "-- unstaged forbidden" > lib/resupply-db/drizzle/0050_unstaged.sql
git add -N lib/resupply-db/drizzle/0050_unstaged.sql
if BASE_REF=HEAD DIFF_TARGET= bash scripts/check-resupply-migration-prefix.sh \
   >/dev/null 2>&1; then
  echo "[self-test] FAIL: H (working-tree mode should have detected forbidden add)" >&2
  exit 1
fi
git rm -f --cached lib/resupply-db/drizzle/0050_unstaged.sql >/dev/null 2>&1 || true
rm -f lib/resupply-db/drizzle/0050_unstaged.sql

# --- I: high prefix far above threshold -------------------------------------
echo "[self-test] scenario I: adding 0099_*.sql should pass"
echo "-- new" > lib/resupply-db/drizzle/0099_high.sql
git add lib/resupply-db/drizzle/0099_high.sql
if ! run_check >/dev/null 2>&1; then
  echo "[self-test] FAIL: I (0099 add should have passed)" >&2
  exit 1
fi
git restore --staged lib/resupply-db/drizzle/0099_high.sql >/dev/null 2>&1 || true
rm -f lib/resupply-db/drizzle/0099_high.sql

echo "[self-test] all scenarios passed"
