#!/usr/bin/env bash
# Self-test for scripts/check-drizzle-drift.sh.
#
# Exercises both the positive and negative paths of the drift checker
# against a sandboxed clone of `lib/resupply-db`. We never mutate the
# real lib — every operation runs inside a tempdir, and the original
# tree is restored on EXIT regardless of how the test exits.
#
# Scenario A (positive — clean tree):
#   1. Snapshot the live `lib/resupply-db/drizzle/` tree.
#   2. Run the real `check-drizzle-drift.sh` against the live tree.
#   3. Expect exit 0 and the "All drizzle schemas are in sync" line.
#   4. Confirm the script restored every drizzle/* file byte-identically
#      (the runtime migrator hashes journal + SQL files, so even
#      whitespace-only edits would corrupt prod).
#
# Scenario B (negative — drifted schema):
#   1. Build a sandbox lib at $SANDBOX_LIB by copying only what
#      drizzle-kit needs (drizzle/, src/, package.json,
#      drizzle.config.ts) and SYMLINKING node_modules so it can
#      resolve drizzle-kit + the workspace catalog without us copying
#      hundreds of MB. We use `cp -a` (not hardlinks) because the test
#      tempdir is typically on a different filesystem from the repo,
#      where hardlinks would fail with EXDEV.
#   2. Replace one schema TS file with a drifted copy (extra column).
#   3. Run a sed-altered copy of `check-drizzle-drift.sh` that points
#      its single LIBS entry at $SANDBOX_LIB.
#   4. Expect exit 1, the "drizzle schema drift detected" line, and
#      the helpful `pnpm --filter @workspace/resupply-db run generate`
#      hint.
#   5. Confirm the sandbox's drizzle/ tree is byte-identical to its
#      pre-run state (the script's snapshot/restore must have undone
#      the regenerated SQL + snapshot files).
#
# DATABASE_URL is required for both scenarios because resupply-db's
# drizzle.config.ts throws on import without it. drizzle-kit generate
# never actually connects — it just reads schema TS + committed
# snapshots — so any syntactically valid postgres URL works.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CHECKER="$REPO_ROOT/scripts/check-drizzle-drift.sh"
LIVE_LIB="$REPO_ROOT/lib/resupply-db"
LIVE_DRIZZLE="$LIVE_LIB/drizzle"

export DATABASE_URL="${DATABASE_URL:-postgres://drift-self-test/none}"

# Place WORK inside REPO_ROOT so the sandbox lib path can be expressed
# as a relative path the checker accepts. The checker joins entries as
# `$REPO_ROOT/$lib_dir`, so an absolute /tmp path would resolve under
# REPO_ROOT rather than where it actually lives. We also need `cp -a`
# to stay on a single filesystem to avoid hardlink issues; tmpfs vs
# ext4 wouldn't affect `cp -a` (which copies, not links), but it does
# matter if anything later tries to hardlink.
WORK="$(mktemp -d -p "$REPO_ROOT" .drizzle-drift-test.XXXXXX)"
PRE_SNAP="$WORK/live-pre"
cp -a "$LIVE_DRIZZLE/." "$PRE_SNAP/"

cleanup() {
  local rc=$?
  # Belt-and-suspenders restore of the live drizzle dir. The checker
  # itself restores on every exit path, but if THIS test crashes mid-
  # execution we still want the working tree intact.
  if [[ -d "$PRE_SNAP" && -d "$LIVE_DRIZZLE" ]]; then
    rm -rf "${LIVE_DRIZZLE:?}"
    mkdir -p "$LIVE_DRIZZLE"
    cp -a "$PRE_SNAP/." "$LIVE_DRIZZLE/"
  fi
  rm -rf "$WORK"
  exit "$rc"
}
trap cleanup EXIT INT TERM

assert_drizzle_dir_unchanged() {
  local label="$1"
  local expected="$2"
  local actual="$3"
  if ! diff -rq "$expected" "$actual" > "$WORK/diff.out" 2>&1; then
    echo "  FAIL [$label]: drizzle/ was not restored byte-identically" >&2
    sed 's/^/    /' "$WORK/diff.out" >&2
    exit 1
  fi
}

# ---------------------------------------------------------------------------
echo "[Scenario A] clean tree — checker should exit 0 and restore drizzle/"
# ---------------------------------------------------------------------------
A_LOG="$WORK/scenario-a.log"
if bash "$CHECKER" > "$A_LOG" 2>&1; then
  if grep -qF 'All drizzle schemas are in sync' "$A_LOG"; then
    echo "  PASS: clean-tree success message present"
  else
    echo "  FAIL: checker exited 0 but did not print success line" >&2
    sed 's/^/    /' "$A_LOG" >&2
    exit 1
  fi
else
  echo "  FAIL: checker exited non-zero on a clean tree" >&2
  sed 's/^/    /' "$A_LOG" >&2
  exit 1
fi
assert_drizzle_dir_unchanged "Scenario A" "$PRE_SNAP" "$LIVE_DRIZZLE"
echo "  PASS: live drizzle/ restored byte-identically"

# ---------------------------------------------------------------------------
echo "[Scenario B] drifted schema — checker should exit 1 and restore drizzle/"
# ---------------------------------------------------------------------------
SANDBOX_LIB="$WORK/sandbox-lib"
mkdir -p "$SANDBOX_LIB"
# Copy only the inputs drizzle-kit reads (deep copy so edits don't
# leak back into the real lib). Symlink node_modules so module
# resolution finds drizzle-kit and the workspace catalog without us
# duplicating hundreds of MB. We deliberately skip dist/, scripts/,
# README.md, vitest config, etc. — drizzle-kit generate doesn't need
# them and copying them just slows the test down.
for entry in src drizzle drizzle.config.ts package.json; do
  if [[ ! -e "$LIVE_LIB/$entry" ]]; then
    echo "  FAIL: expected sandbox source missing: $LIVE_LIB/$entry" >&2
    exit 1
  fi
  cp -a "$LIVE_LIB/$entry" "$SANDBOX_LIB/$entry"
done
ln -s "$LIVE_LIB/node_modules" "$SANDBOX_LIB/node_modules"

DRIFT_FILE="$SANDBOX_LIB/src/schema/auth/users.ts"
if [[ ! -f "$DRIFT_FILE" ]]; then
  echo "  FAIL: expected schema file missing in sandbox: $DRIFT_FILE" >&2
  exit 1
fi
cp "$DRIFT_FILE" "$WORK/users.ts.orig"
rm "$DRIFT_FILE"
# Insert one extra column INSIDE the columns object — i.e. immediately
# before the `\n  },\n  (t) => ({` boundary that closes the columns
# literal and opens the table-options callback. GNU sed's `-z` mode
# treats the file as one NUL-delimited record so we can match across
# newlines. We pick this boundary because every drizzle pgTable
# definition ends with it; if a future schema refactor changes that
# pattern, the test will fail loudly with "drift injection did not
# modify ..." instead of silently corrupting the file.
sed -z 's|\n  },\n  (t) => ({|\n    fakeDriftColumnSelfTest: text("fake_drift_column_self_test"),\n  },\n  (t) => ({|' \
  "$WORK/users.ts.orig" > "$DRIFT_FILE"
if diff -q "$WORK/users.ts.orig" "$DRIFT_FILE" > /dev/null; then
  echo "  FAIL: drift injection did not modify $DRIFT_FILE" >&2
  echo "         (the schema file's pgTable closure pattern may have changed —" >&2
  echo "          update the sed expression in scripts/check-drizzle-drift.sh.test)" >&2
  exit 1
fi

# Build a sed-altered checker that points at the sandbox lib instead
# of the live one. The original LIBS line is the only thing we touch.
# Use `#` as the sed delimiter because the LIBS entry itself contains
# `|` separators that would otherwise terminate the s/// command.
SANDBOX_CHECKER="$WORK/check-drizzle-drift.sandbox.sh"
SANDBOX_REL="${SANDBOX_LIB#"$REPO_ROOT/"}"
sed "s#@workspace/resupply-db|lib/resupply-db|lib/resupply-db/drizzle#@workspace/resupply-db|${SANDBOX_REL}|${SANDBOX_REL}/drizzle#" \
  "$CHECKER" > "$SANDBOX_CHECKER"
if ! grep -qF "${SANDBOX_REL}/drizzle" "$SANDBOX_CHECKER"; then
  echo "  FAIL: failed to retarget the sandbox checker (LIBS sed didn't match)" >&2
  exit 1
fi

# Snapshot the sandbox's drizzle/ to verify the sandboxed checker
# restores it after detecting drift.
SANDBOX_PRE="$WORK/sandbox-pre"
cp -a "$SANDBOX_LIB/drizzle/." "$SANDBOX_PRE/"

B_LOG="$WORK/scenario-b.log"
set +e
bash "$SANDBOX_CHECKER" > "$B_LOG" 2>&1
B_RC=$?
set -e

if [[ $B_RC -eq 0 ]]; then
  echo "  FAIL: drifted schema did not trigger a non-zero exit" >&2
  sed 's/^/    /' "$B_LOG" >&2
  exit 1
fi
if ! grep -qF 'drizzle schema drift detected' "$B_LOG"; then
  echo "  FAIL: drift error banner missing from checker output" >&2
  sed 's/^/    /' "$B_LOG" >&2
  exit 1
fi
if ! grep -qF 'pnpm --filter @workspace/resupply-db run generate' "$B_LOG"; then
  echo "  FAIL: contributor-facing fix hint missing from checker output" >&2
  sed 's/^/    /' "$B_LOG" >&2
  exit 1
fi
echo "  PASS: drift detected with helpful message (exit ${B_RC})"

assert_drizzle_dir_unchanged "Scenario B" "$SANDBOX_PRE" "$SANDBOX_LIB/drizzle"
echo "  PASS: sandbox drizzle/ restored byte-identically after drift"

# Final paranoia: confirm the LIVE tree was never mutated by Scenario B
# either (it shouldn't have been — Scenario B only touched the sandbox).
assert_drizzle_dir_unchanged "post-Scenario-B live tree" "$PRE_SNAP" "$LIVE_DRIZZLE"
echo "  PASS: live drizzle/ untouched by Scenario B"

echo
echo "All drift self-tests passed."
