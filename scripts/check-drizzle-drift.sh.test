#!/usr/bin/env bash
# Self-test for scripts/check-drizzle-drift.sh.
#
# Task #37 deleted `@workspace/db` (its tables were folded into
# `@workspace/resupply-db`'s schema/storefront/), and `lib/resupply-db`
# is intentionally NOT yet enrolled in the drift checker because its
# snapshot meta chain (drizzle/meta/000N_snapshot.json) only covers
# 0000-0003 while 27+ migration SQL files have shipped. drizzle-kit
# generate short-circuits on a "snapshot collision" before it can
# compute a diff, so the checker has no libs to scan.
#
# Until the resupply-db snapshot chain is rebuilt and that lib is
# added back to the LIBS array in check-drizzle-drift.sh, this
# self-test simply confirms the checker still exits 0 on an empty
# LIBS list (the no-op path). When the lib is re-enrolled, restore
# the previous Scenario A (clean tree) + Scenario B (drifted schema)
# fixture pair against the resupply schema; see git history
# (pre-Task-#37 revision of this file) for the storefront
# implementation that can be ported.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CHECKER="$REPO_ROOT/scripts/check-drizzle-drift.sh"

# The checker requires DATABASE_URL set or it skips (exit 0) before
# reaching the LIBS loop. We deliberately set a syntactically valid
# but unused value so the script proceeds past the env-var guard and
# we exercise the real LIBS-empty path.
export DATABASE_URL="${DATABASE_URL:-postgres://drift-self-test/none}"

echo "[self-test] checker should exit 0 on empty LIBS list"
if out="$(bash "$CHECKER" 2>&1)"; then
  if echo "$out" | grep -qF '(no libs to check'; then
    echo "  PASS: empty-LIBS no-op message present"
  else
    echo "  FAIL: checker exited 0 but did not print the expected no-op message" >&2
    echo "  output:" >&2
    echo "$out" | sed 's/^/    /' >&2
    exit 1
  fi
else
  echo "  FAIL: checker exited non-zero on empty LIBS" >&2
  echo "  output:" >&2
  echo "$out" | sed 's/^/    /' >&2
  exit 1
fi

echo "All drift self-tests passed."
