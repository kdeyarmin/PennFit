# =============================================================================
# PennPaps / Resupply environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env` (which is git-ignored) and fill in real values.
# Only set the variables required by the apps/services you actually run.
#
# Variables are grouped by what they actually are:
#   1. SECRETS      — credentials, API keys, signing/encryption keys.
#                     Treat as world-sensitive. Never commit real values.
#   2. CONFIGURATION — non-secret runtime settings: ports, URLs, addresses,
#                      allow-lists, feature flags, paths.
# =============================================================================


# =============================================================================
# 1. SECRETS — never commit real values; rotate on suspected leak.
# =============================================================================

# --- Postgres -----------------------------------------------------------------
# Connection string includes the password — treat as a secret.
DATABASE_URL=postgres://user:password@localhost:5432/pennpaps

# --- Supabase (REQUIRED) -----------------------------------------------------
# The resupply API and in-process worker read and write Postgres
# through @workspace/resupply-db's Supabase service-role client
# (see lib/resupply-db/src/supabase-client.ts) — this is the only
# runtime data path. URL is safe to expose; the service-role key
# bypasses RLS and MUST stay server-side. Find both in Studio →
# Project Settings → API.
#
# DATABASE_URL above is still required: scripts/migrate.mjs uses it
# to apply SQL migrations, and a small number of legacy worker
# paths that have not yet been ported to PostgREST call into the
# pg pool via getDbPool().
#
# IMPORTANT: the `resupply` and `resupply_auth` schemas must be added
# to Studio → Project Settings → API → "Exposed schemas" or every
# Supabase JS query returns "schema must be one of: public".
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me_with_service_role_key

# --- Auth (in-house) ---------------------------------------------------------
# No auth secrets are required at boot. Passwords are hashed with plain
# argon2id. The previous AUTH_PASSWORD_PEPPER server-side HMAC was removed
# in the Task #38 follow-up (see docs/resupply/adr/014-in-house-auth.md
# "Amendment, Task #38"); a stale value in the environment is silently
# ignored and can be deleted. Optional knobs:
#   AUTH_SESSION_TTL_DAYS         (default 14)
#   AUTH_EMAIL_TOKEN_TTL_HOURS    (default 24)

# --- Resupply link signing (REQUIRED at boot) --------------------------------
# 32+ byte secret used to HMAC-sign the short-lived patient links delivered
# in SMS / email reminders (see lib/resupply-secrets). The resupply-api
# refuses to start without it — see artifacts/resupply-api/src/lib/env-check.ts.
# Rotating this value invalidates every in-flight reminder link, so plan a
# rotation around the link TTL (default 7 days).
#
# Generate with: openssl rand -base64 48
RESUPPLY_LINK_HMAC_KEY=replace_me_with_32_byte_secret

# Note: RESUPPLY_AUDIT_HMAC_KEY was retired with migration 0156 — the
# HIPAA §164.312(b) tamper-evident audit chain (and the rest of the
# compliance machinery) has been removed from the product. Stale
# values in the environment are silently ignored.

# Note: migration 0025 stripped pgcrypto column-level PHI encryption and
# dropped the phone_lookup table, so the legacy RESUPPLY_MASTER_KEY /
# RESUPPLY_DATA_KEY / RESUPPLY_PHONE_HMAC_KEY secrets are no longer read by
# any code path. Delete them from your secrets store if they're still set.

# --- Vendor API keys ---------------------------------------------------------
SENDGRID_API_KEY=SG.replace_me
TWILIO_AUTH_TOKEN=replace_me
# OpenAI — used by the voice agent (gpt-realtime + gpt-4o-mini-transcribe).
# Also acts as the LLM fallback when ANTHROPIC_API_KEY is not set.
OPENAI_API_KEY=sk-replace_me
# Anthropic — used by the storefront chatbot, sleep coach, and SMS
# intent classifier. When set, takes priority over OPENAI_API_KEY for
# every text-only LLM call. Sonnet 4.6 + Haiku 4.5 produce noticeably
# warmer, more human-sounding replies than gpt-4o-mini-class models.
# Leave blank to keep OpenAI as the sole LLM provider.
ANTHROPIC_API_KEY=sk-ant-replace_me
# Deepgram — speech-to-text. Used for post-call audit transcription
# (higher accuracy than gpt-4o-mini-transcribe on telephony audio).
# Optional; leave blank to skip Deepgram and rely on OpenAI Realtime's
# built-in transcription. Get a key at https://console.deepgram.com.
DEEPGRAM_API_KEY=
# ElevenLabs — text-to-speech. Optional; when set, deployments can opt
# into ElevenLabs voices on the voice agent path for the most natural
# voice quality available. Leave blank to use OpenAI Realtime's
# built-in voices (default: cedar). Get a key at https://elevenlabs.io.
ELEVENLABS_API_KEY=
STRIPE_SECRET_KEY=sk_test_replace_me
# Stripe webhook signing secret (whsec_...) — required for the
# /webhooks/stripe handler to verify event signatures. Webhook
# verification fails closed when missing.
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_replace_me

# --- Webhook verification (public keys, but bundled with vendor accounts) ----
# Public key used to verify SendGrid event webhooks (PEM/base64).
SENDGRID_EVENT_WEBHOOK_PUBLIC_KEY=


# =============================================================================
# 2. CONFIGURATION — not secret. Safe to share, log, or check into infra repos.
# =============================================================================

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
# Optional base path prefix for the API server (leave empty for root).
BASE_PATH=


# Sliding session lifetime (days). Default 14.
AUTH_SESSION_TTL_DAYS=14
# Email-token lifetime in hours (verify / reset). Default 24.
AUTH_EMAIL_TOKEN_TTL_HOURS=24

# --- CORS / Allowed origins (REQUIRED at boot in production) ---------------
# Comma-separated list of allowed origins (scheme+host form). In
# NODE_ENV=production the resupply-api throws at boot if BOTH
# RESUPPLY_ALLOWED_ORIGINS and RAILWAY_PUBLIC_DOMAIN are empty.
# On Railway deployments RAILWAY_PUBLIC_DOMAIN is auto-populated by the
# platform, so this var is optional there; set it explicitly when you
# need multiple origins (e.g. custom domain + the *.up.railway.app
# fallback, or separate API + storefront hosts).
RESUPPLY_ALLOWED_ORIGINS=http://localhost:5173

# --- Public base URLs (no trailing slash) -----------------------------------
SHOP_PUBLIC_BASE_URL=http://localhost:5173
REMINDER_PUBLIC_BASE_URL=http://localhost:5173
RESUPPLY_VOICE_PUBLIC_BASE_URL=http://localhost:3000
# Internal admin console origin. Used by api-server to build links into
# the dashboard from admin-only emails / system-info responses.
RESUPPLY_DASHBOARD_PUBLIC_BASE_URL=http://localhost:5173
# Public origin of the PennPaps admin console (used in admin-user
# invitation emails sent from api-server).
PENN_ADMIN_PUBLIC_BASE_URL=http://localhost:5173

# --- Email-from + recipient addresses (not secrets) -------------------------
# Single From address for the entire platform — every outbound email funnels
# through lib/resupply-email's createSendgridClient(). Production value is
# info@pennpaps.com.
SENDGRID_FROM_EMAIL=info@pennpaps.com
SENDGRID_FROM_NAME=PennPaps
# Where Penn Fit fulfillment receives new mask orders (recipient, not sender).
PENN_FULFILLMENT_EMAIL=fulfillment@example.com
# Optional: shared inbox that gets a "ping, customer messaged you" email
# every time a signed-in shopper posts via /shop/me/messages (PR #57).
# Subject-only, never the message body. Leave blank to disable; the
# message still lands in /admin/conversations regardless.
SHOP_CSR_INBOX_EMAIL=

# --- Worker job feature flags -----------------------------------------------
# Abandoned-fitter re-engagement nudge (fitter-lead.reengage cron).
# Daily 09:37 UTC scan of resupply.fitter_leads → email patients who opted
# in but never finished. OFF by default so a staging deploy with a real
# SENDGRID_API_KEY can't accidentally email production addresses. Set to 1
# in production to turn the cron on.
RESUPPLY_FITTER_REENGAGE_ENABLED=0

# Cart-abandonment hourly cron (cart-abandonment.scan).
# Runs the same dispatcher that backs POST /admin/shop/abandoned-carts/
# send-due so abandoned carts get nudged without a human clicking the
# button. Suppression rules (comm-prefs, DND, 24h cool-down,
# single-nudge-per-cart) are unchanged. OFF by default so a credentialed
# staging deploy can't accidentally start nudging real abandoned carts.
RESUPPLY_CART_ABANDONMENT_CRON_ENABLED=0

# Failed-email order digest (failed-order-emails.digest cron).
# Daily 13:00 UTC scan of public.orders for rows with email_status=failed
# in the last 24 hours; sends a single summary email to
# RESUPPLY_ADMIN_ALERTS_EMAIL so ops can chase the failures without
# hand-querying the DB. PHI policy: ONLY order_reference + created_at
# leave the database — no patient names, no email errors that might
# echo back the customer's address. OFF by default; requires the alerts
# recipient below to also be set.
RESUPPLY_FAILED_EMAIL_DIGEST_ENABLED=0

# Recipient address for ops alerts (failed-email digest, future
# operational alerts). When unset and a worker tries to send to it, the
# worker logs the alert and exits cleanly — no error. Distinct from
# SENDGRID_FROM_EMAIL (the From address used across all transactional
# email) and PENN_FULFILLMENT_EMAIL (the order-routing recipient).
RESUPPLY_ADMIN_ALERTS_EMAIL=

# --- Practice display name --------------------------------------------------
# Rendered in reminder/voice/messaging copy (e.g. "Hi from {name}").
# Defaults to "PennPaps" when unset.
RESUPPLY_PRACTICE_NAME=PennPaps

# --- Operator / role email allow-lists (comma-separated, DISPLAY-ONLY) ------
# The role gate is DB-driven: artifacts/resupply-api/src/middlewares/
# requireAdmin.ts reads `auth.users.role` directly. These env vars are
# read only by routes/admin/system-info.ts to populate the
# allowlist-count tiles on /admin/operations; they do NOT affect
# authorization. Bootstrap the first admin via
#   pnpm --filter @workspace/scripts auth:bootstrap-admin --email=… --role=admin
# Safe to leave all three empty.
RESUPPLY_ADMIN_EMAILS=
RESUPPLY_AGENT_EMAILS=
RESUPPLY_OPERATOR_EMAILS=

# --- Telecom identifiers (Twilio account SID + numbers — not secrets) -------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15555550123
TWILIO_MESSAGING_SERVICE_SID=

# --- Physician fax outreach — Twilio Programmable Fax ------------------
# When set alongside TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN, the
# /admin/physician-fax-outreach endpoint dispatches the Rx-renewal cover
# letter directly to the prescribing physician's fax machine via Twilio.
# TWILIO_FAX_FROM_NUMBER must be a fax-enabled number on your Twilio
# account (E.164 format, e.g. +12155550123).
# RESUPPLY_VOICE_PUBLIC_BASE_URL is also required so Twilio can fetch the
# cover-letter PDF and deliver status/inbound callbacks.
# Twilio webhook URLs to configure in the Twilio console:
#   Outbound status: {RESUPPLY_VOICE_PUBLIC_BASE_URL}/resupply-api/fax/status-callback
#   Inbound fax:     {RESUPPLY_VOICE_PUBLIC_BASE_URL}/resupply-api/fax/inbound
TWILIO_FAX_FROM_NUMBER=

# --- Web Push (VAPID) — feature #4 -----------------------------------------
# Generate once: `node -e 'console.log(require("web-push").generateVAPIDKeys())'`
# All three are needed to actually send/deliver web pushes. If
# WEB_PUSH_VAPID_PUBLIC_KEY is unset, the public-key getter returns 503 and
# the SPA hides the "Enable push" toggle. Subject must be a mailto: URL or
# HTTPS; push services use it as the abuse-contact for your VAPID identity.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:ops@pennpaps.com

# --- Object storage (Supabase Storage) --------------------------------------
# The API stores customer-uploaded attachments (POD photos, prescription
# PDFs, MMS media) in Supabase Storage buckets. Create the buckets in
# Studio → Storage and set the names below. ACL metadata for each
# stored object is tracked in resupply.object_storage_acls (migration
# 0165), not as bucket-level RLS.
SUPABASE_STORAGE_BUCKET_PRIVATE=attachments
# Optional — only set when searchPublicObject() callers need a separate
# bucket for public assets. Leave blank otherwise.
SUPABASE_STORAGE_BUCKET_PUBLIC=

# --- Office Ally clearinghouse (837P claim submission) ---------------------
# As of migration 0132 the AUTHORITATIVE source for both the DME
# organization identity (NPI, tax id, legal name, address, phone) and
# the clearinghouse SFTP config (ETIN, host, key paths) is the
# Supabase-backed resupply.dme_organization + resupply.clearinghouse_credentials
# tables. The env vars below remain as a fallback for dev / preview
# environments where the DB rows haven't been seeded yet.
#
# When the DB rows exist, the env vars are IGNORED. The admin UI
# under /admin/dme-organization + /admin/clearinghouse-credentials is
# the editable surface; changes take effect on the next request
# without a deploy.
#
# When fully set, the resupply-api builds 837P EDI claim files and
# uploads them to Office Ally via the system `sftp` binary. When any
# required variable is missing AND no DB rows are present, the
# adapter degrades to "stub mode" — it still builds the EDI payload
# but writes it to OFFICE_ALLY_FILE_OUTBOX_DIR instead of uploading.
#
# Required for live mode:
#   OFFICE_ALLY_USERNAME              — SFTP username (your OA submitter id)
#   OFFICE_ALLY_PRIVATE_KEY_PATH      — absolute path to the 0600 SSH key
#   OFFICE_ALLY_KNOWN_HOSTS_PATH      — absolute path to a known_hosts pin
#   OFFICE_ALLY_ETIN                  — your submitter ETIN (assigned by OA)
#   OFFICE_ALLY_BILLING_NPI           — type-2 NPI for the DME entity
#   OFFICE_ALLY_BILLING_TAX_ID        — 9-digit EIN (no dashes)
#   OFFICE_ALLY_BILLING_ORG_NAME      — legal name as on the EIN
#   OFFICE_ALLY_BILLING_ADDRESS_LINE1
#   OFFICE_ALLY_BILLING_CITY
#   OFFICE_ALLY_BILLING_STATE         — 2-char USPS state code
#   OFFICE_ALLY_BILLING_ZIP           — 5 or 9 digit ZIP (no dash)
#
# Optional:
#   OFFICE_ALLY_HOST                  — default sftp10.officeally.com
#   OFFICE_ALLY_PORT                  — default 22
#   OFFICE_ALLY_REMOTE_INBOX          — default `inbound`
#   OFFICE_ALLY_USAGE_INDICATOR=T     — production = P, test = T
#   OFFICE_ALLY_FILE_OUTBOX_DIR       — file-drop dir for stub mode
#   OFFICE_ALLY_STUB=1                — force stub mode (even with creds)
#   OFFICE_ALLY_CONTACT_NAME          — printed on the 1000A PER segment
#   OFFICE_ALLY_CONTACT_PHONE_E164    — printed on the 1000A PER segment
OFFICE_ALLY_USERNAME=
OFFICE_ALLY_PRIVATE_KEY_PATH=
OFFICE_ALLY_KNOWN_HOSTS_PATH=
OFFICE_ALLY_ETIN=
OFFICE_ALLY_BILLING_NPI=
OFFICE_ALLY_BILLING_TAX_ID=
OFFICE_ALLY_BILLING_ORG_NAME=
OFFICE_ALLY_BILLING_ADDRESS_LINE1=
OFFICE_ALLY_BILLING_CITY=
OFFICE_ALLY_BILLING_STATE=
OFFICE_ALLY_BILLING_ZIP=
OFFICE_ALLY_USAGE_INDICATOR=T

# --- AI claim intelligence (uses OPENAI_API_KEY above) ----------------------
# The AI claim scrubber + denial analyzer call OpenAI Chat Completions
# via plain fetch (same posture as lib/messaging/ai-fallback-impl.ts).
# No additional API key is required — they reuse OPENAI_API_KEY. When
# that key is unset, the scrub + analyzer routes still complete but
# persist verdict='errored' and the UI surfaces the missing-key state.
#
# Optional knobs:
#   OPENAI_CLAIM_MODEL              — model id for scrub + denial calls.
#                                     Default `gpt-4o-mini`.
#   OPENAI_CLAIM_TIMEOUT_MS         — per-call hard timeout. Default 20000.
#
# Cost shape (Apr 2026 list price for gpt-4o-mini): each scrub run
# averages ~2k prompt + ~500 completion tokens = ~$0.0005 per scrub;
# each denial analysis ~3k + 800 = ~$0.0009. Set OPENAI_CLAIM_MODEL=gpt-4o
# to use the higher-tier model on appeals where the cost is justified.

# --- Codegen output overrides (used by scripts/codegen) ---------------------
# Leave unset to use defaults inside the repo.
CODEGEN_OUT_PENNPAPS_CLIENT=
CODEGEN_OUT_PENNPAPS_ZOD=
CODEGEN_OUT_RESUPPLY_CLIENT=

# --- Vite client (browser-exposed feature flags / display values) -----------
VITE_RESUPPLY_CONTACT_EMAIL=support@example.com

# --- Railway (set automatically when running on Railway; usually leave blank) --
# RAILWAY_PUBLIC_DOMAIN is the canonical *.up.railway.app host (or your
# custom domain) that Railway exposes the service on. The app reads it
# as a CORS-allowlist fallback and to synthesize public URLs for
# Twilio/Stripe callbacks when RESUPPLY_VOICE_PUBLIC_BASE_URL is unset.
RAILWAY_PUBLIC_DOMAIN=
