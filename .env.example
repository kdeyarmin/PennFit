# =============================================================================
# PennFit / Resupply environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env` (which is git-ignored) and fill in real values.
# Only set the variables required by the apps/services you actually run.
#
# Variables are grouped by what they actually are:
#   1. SECRETS      — credentials, API keys, signing/encryption keys.
#                     Treat as world-sensitive. Never commit real values.
#   2. CONFIGURATION — non-secret runtime settings: ports, URLs, addresses,
#                      allow-lists, feature flags, paths.
# =============================================================================


# =============================================================================
# 1. SECRETS — never commit real values; rotate on suspected leak.
# =============================================================================

# --- Postgres -----------------------------------------------------------------
# Connection string includes the password — treat as a secret.
DATABASE_URL=postgres://user:password@localhost:5432/pennfit

# --- Auth (Clerk) -------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_replace_me

# --- Resupply key material ---------------------------------------------------
# Single 32+ byte master secret. The three subkeys used inside the resupply
# stack — bulk PHI encryption (pgcrypto), reminder/email link signing (HMAC),
# and phone-number lookup (HMAC) — are HKDF-derived from this value with
# distinct domain-separated `info` labels. Cryptographic separation between
# the three purposes is preserved (compromise of one derived key does not
# reveal the master or the siblings) but you only have one secret to
# generate, store, and rotate.
#
# Generate with: openssl rand -base64 48
RESUPPLY_MASTER_KEY=replace_me_with_32_byte_secret

# --- Resupply key material (LEGACY — pre-master-key deployments) -------------
# Older deployments set these three explicitly instead of RESUPPLY_MASTER_KEY.
# When present, each takes precedence over the value derived from
# RESUPPLY_MASTER_KEY for that specific purpose, so existing pgp_sym_encrypt
# blobs and phone_lookup HMACs continue to work unchanged.
#
# Migration: set RESUPPLY_MASTER_KEY alongside these, run
# `pnpm --filter @workspace/resupply-db rotate-to-master-key`, then drop
# RESUPPLY_DATA_KEY and RESUPPLY_PHONE_HMAC_KEY. Leave RESUPPLY_LINK_HMAC_KEY
# in place for one full link-token TTL (default 7 days) before dropping it,
# so in-flight email CTAs continue to verify.
#
# RESUPPLY_DATA_KEY=replace_me_with_32_byte_secret
# RESUPPLY_LINK_HMAC_KEY=replace_me_with_32_byte_secret
# RESUPPLY_PHONE_HMAC_KEY=replace_me_with_32_byte_secret

# --- Vendor API keys ---------------------------------------------------------
SENDGRID_API_KEY=SG.replace_me
TWILIO_AUTH_TOKEN=replace_me
OPENAI_API_KEY=sk-replace_me
STRIPE_SECRET_KEY=sk_test_replace_me

# --- Webhook verification (public keys, but bundled with vendor accounts) ----
# Public key used to verify SendGrid event webhooks (PEM/base64).
SENDGRID_EVENT_WEBHOOK_PUBLIC_KEY=


# =============================================================================
# 2. CONFIGURATION — not secret. Safe to share, log, or check into infra repos.
# =============================================================================

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
# Optional base path prefix for the API server (leave empty for root).
BASE_PATH=

# --- CORS / Allowed origins (comma-separated) -------------------------------
PENN_ALLOWED_ORIGINS=http://localhost:5173
RESUPPLY_ALLOWED_ORIGINS=http://localhost:5173

# --- Public base URLs (no trailing slash) -----------------------------------
SHOP_PUBLIC_BASE_URL=http://localhost:5173
REMINDER_PUBLIC_BASE_URL=http://localhost:5173
RESUPPLY_VOICE_PUBLIC_BASE_URL=http://localhost:3000

# --- Public auth identifiers (Clerk) ----------------------------------------
# Vite-exposed publishable key (safe for the browser).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# --- Email-from + recipient addresses (not secrets) -------------------------
SENDGRID_FROM_EMAIL=no-reply@example.com
SENDGRID_FROM_NAME=PennFit
PENN_FROM_EMAIL=no-reply@example.com
PENN_FULFILLMENT_EMAIL=fulfillment@example.com

# --- Operator / role email allow-lists (comma-separated) --------------------
RESUPPLY_ADMIN_EMAILS=
RESUPPLY_AGENT_EMAILS=
RESUPPLY_OPERATOR_EMAILS=

# --- Telecom identifiers (Twilio account SID + numbers — not secrets) -------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15555550123
TWILIO_MESSAGING_SERVICE_SID=

# --- Object storage (Replit Object Storage) ---------------------------------
PRIVATE_OBJECT_DIR=
# Comma-separated search paths.
PUBLIC_OBJECT_SEARCH_PATHS=

# --- Codegen output overrides (used by scripts/codegen) ---------------------
# Leave unset to use defaults inside the repo.
CODEGEN_OUT_PENN_FIT_CLIENT=
CODEGEN_OUT_PENN_FIT_ZOD=
CODEGEN_OUT_RESUPPLY_CLIENT=

# --- Vite client (browser-exposed feature flags / display values) -----------
VITE_ENABLE_DEMO=false
VITE_RESUPPLY_CONTACT_EMAIL=support@example.com

# --- Replit (set automatically when running on Replit; usually leave blank) --
REPL_ID=
REPLIT_DEV_DOMAIN=
REPLIT_DOMAINS=
