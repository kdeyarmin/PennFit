# =============================================================================
# PennPaps / Resupply environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env` (which is git-ignored) and fill in real values.
# Only set the variables required by the apps/services you actually run.
#
# Variables are grouped by what they actually are:
#   1. SECRETS      — credentials, API keys, signing/encryption keys.
#                     Treat as world-sensitive. Never commit real values.
#   2. CONFIGURATION — non-secret runtime settings: ports, URLs, addresses,
#                      allow-lists, feature flags, paths.
# =============================================================================


# =============================================================================
# 1. SECRETS — never commit real values; rotate on suspected leak.
# =============================================================================

# --- Postgres -----------------------------------------------------------------
# Connection string includes the password — treat as a secret.
DATABASE_URL=postgres://user:password@localhost:5432/pennpaps

# --- Auth (in-house) ---------------------------------------------------------
# No auth secrets are required at boot. Passwords are hashed with plain
# argon2id (the previous AUTH_PASSWORD_PEPPER server-side HMAC was
# removed in the Task #38 follow-up). Any AUTH_PASSWORD_PEPPER value
# inherited from an older deploy is silently ignored — delete it from
# your secrets store. Optional knobs:
#   AUTH_SESSION_TTL_DAYS         (default 14)
#   AUTH_EMAIL_TOKEN_TTL_HOURS    (default 24)

# --- Resupply link signing (REQUIRED at boot) --------------------------------
# 32+ random bytes used to HMAC-sign the short-lived patient links delivered
# in SMS / email reminders. resupply-api refuses to start if this is unset.
# Rotating the value invalidates in-flight links.
#
# Generate with: openssl rand -base64 48
RESUPPLY_LINK_HMAC_KEY=replace_me_with_32_byte_secret

# --- Resupply key material (LEGACY — removed; safe to delete) ----------------
# Migration 0025 stripped pgcrypto column-level PHI encryption and dropped
# the `phone_lookup` table, so RESUPPLY_MASTER_KEY, RESUPPLY_DATA_KEY, and
# RESUPPLY_PHONE_HMAC_KEY are no longer read by any code path. They are
# documented here only so operators upgrading from a pre-2026-05 deploy
# know they can be removed from their secrets store. The one-shot rotation
# helper (`pnpm --filter @workspace/resupply-db rotate-to-master-key`) is
# the only remaining consumer and reads them ad-hoc when invoked.
#
# RESUPPLY_MASTER_KEY=...
# RESUPPLY_DATA_KEY=...
# RESUPPLY_PHONE_HMAC_KEY=...

# --- Vendor API keys ---------------------------------------------------------
SENDGRID_API_KEY=SG.replace_me
TWILIO_AUTH_TOKEN=replace_me
OPENAI_API_KEY=sk-replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
# Stripe webhook signing secret (whsec_...) — required for the
# /webhooks/stripe handler to verify event signatures. Webhook
# verification fails closed when missing.
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_replace_me

# --- Webhook verification (public keys, but bundled with vendor accounts) ----
# Public key used to verify SendGrid event webhooks (PEM/base64).
SENDGRID_EVENT_WEBHOOK_PUBLIC_KEY=


# =============================================================================
# 2. CONFIGURATION — not secret. Safe to share, log, or check into infra repos.
# =============================================================================

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
# Optional base path prefix for the API server (leave empty for root).
BASE_PATH=


# Sliding session lifetime (days). Default 14.
AUTH_SESSION_TTL_DAYS=14
# Email-token lifetime in hours (verify / reset). Default 24.
AUTH_EMAIL_TOKEN_TTL_HOURS=24

# --- CORS / Allowed origins (comma-separated) -------------------------------
PENN_ALLOWED_ORIGINS=http://localhost:5173
RESUPPLY_ALLOWED_ORIGINS=http://localhost:5173

# --- Public base URLs (no trailing slash) -----------------------------------
SHOP_PUBLIC_BASE_URL=http://localhost:5173
REMINDER_PUBLIC_BASE_URL=http://localhost:5173
RESUPPLY_VOICE_PUBLIC_BASE_URL=http://localhost:3000
# Internal admin console origin. Used by api-server to build links into
# the dashboard from admin-only emails / system-info responses.
RESUPPLY_DASHBOARD_PUBLIC_BASE_URL=http://localhost:5173
# Public origin of the PennPaps admin console (used in admin-user
# invitation emails sent from api-server).
PENN_ADMIN_PUBLIC_BASE_URL=http://localhost:5173

# --- Email-from + recipient addresses (not secrets) -------------------------
SENDGRID_FROM_EMAIL=no-reply@example.com
SENDGRID_FROM_NAME=PennPaps
PENN_FROM_EMAIL=no-reply@example.com
PENN_FULFILLMENT_EMAIL=fulfillment@example.com

# --- Practice display name --------------------------------------------------
# Rendered in reminder/voice/messaging copy (e.g. "Hi from {name}").
# Defaults to "PennPaps" when unset.
RESUPPLY_PRACTICE_NAME=PennPaps

# --- Operator / role email allow-lists (comma-separated) --------------------
RESUPPLY_ADMIN_EMAILS=
RESUPPLY_AGENT_EMAILS=
RESUPPLY_OPERATOR_EMAILS=

# --- Telecom identifiers (Twilio account SID + numbers — not secrets) -------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15555550123
TWILIO_MESSAGING_SERVICE_SID=

# --- Object storage (GCS-compatible; Replit Object Storage in prod) ---------
# The implementation uses @google-cloud/storage. Replit Object Storage
# exposes a GCS-compatible API and is the production backend; any other
# GCS-compatible endpoint works locally.
PRIVATE_OBJECT_DIR=
# Comma-separated search paths.
PUBLIC_OBJECT_SEARCH_PATHS=

# --- Codegen output overrides (used by scripts/codegen) ---------------------
# Leave unset to use defaults inside the repo.
CODEGEN_OUT_PENNPAPS_CLIENT=
CODEGEN_OUT_PENNPAPS_ZOD=
CODEGEN_OUT_RESUPPLY_CLIENT=

# --- Vite client (browser-exposed feature flags / display values) -----------
VITE_ENABLE_DEMO=false
VITE_RESUPPLY_CONTACT_EMAIL=support@example.com

# --- Replit (set automatically when running on Replit; usually leave blank) --
REPL_ID=
REPLIT_DEV_DOMAIN=
REPLIT_DOMAINS=
