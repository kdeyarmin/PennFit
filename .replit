modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Resupply Worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "resupply-check"

[[workflows.workflow]]
name = "Resupply Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/resupply-worker run dev"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "resupply-check"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/check-resupply-architecture.sh --self-test && bash scripts/check-resupply-architecture.sh && pnpm -r --filter '@workspace/resupply-*' run typecheck && pnpm -r --filter '@workspace/resupply-*' run test"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 19334
externalPort = 3003

[[ports]]
localPort = 20466
externalPort = 3002

[[ports]]
localPort = 25632
externalPort = 3000

[userenv]

[userenv.shared]
VITE_CLERK_PUBLISHABLE_KEY = "pk_test_cGxlYXNpbmctYW5jaG92eS00MS5jbGVyay5hY2NvdW50cy5kZXYk"
