modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "gce"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 8084
externalPort = 5173

[[ports]]
localPort = 8085
externalPort = 5000

[[ports]]
localPort = 19334
externalPort = 3003

[[ports]]
localPort = 20466
externalPort = 3002

[[ports]]
localPort = 25632
externalPort = 3000

[userenv]

[userenv.shared]
RESUPPLY_ADMIN_EMAILS = "info@pennpaps.com"
RESUPPLY_OPERATOR_EMAILS = "info@pennpaps.com"

[userenv.development]
PENN_ADMIN_EMAILS = "info@pennpaps.com"

[objectStorage]
defaultBucketID = "replit-objstore-a89f4666-9708-424b-b390-3f9949919d52"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "build-fitter"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "build-api"

[[workflows.workflow]]
name = "build-fitter"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/cpap-fitter run build"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "build-api"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/resupply-api run build"

[workflows.workflow.metadata]
isValidation = true
